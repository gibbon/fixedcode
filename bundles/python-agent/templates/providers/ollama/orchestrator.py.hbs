import asyncio
import logging
import httpx
from dataclasses import dataclass

logger = logging.getLogger(__name__)


@dataclass
class AgentConfig:
    name: str
    url: str
    critical: bool = True


@dataclass
class AgentResult:
    agent_name: str
    status: str
    output: str | None = None
    error: str | None = None


AGENTS: list[AgentConfig] = [
{{#each agents}}
    AgentConfig(name="{{this.name.kebab}}", url="http://localhost:{{@root.port}}/{{this.name.kebab}}", critical={{#if this.critical}}True{{else}}False{{/if}}),
{{/each}}
]


async def route_{{routing}}(input_text: str, session_id: str | None = None) -> list[AgentResult]:
    results: list[AgentResult] = []
    context = input_text

    async with httpx.AsyncClient(timeout=120) as client:
        for agent in AGENTS:
            try:
                response = await client.post(
                    f"{agent.url}/query",
                    json={"message": context, "session_id": session_id},
                )
                response.raise_for_status()
                data = response.json()
                result = AgentResult(agent_name=agent.name, status="completed", output=data.get("output"))
                results.append(result)
                context = f"{context}\n\n--- Output from {agent.name} ---\n{data.get('output', '')}"
            except Exception as e:
                error_result = AgentResult(agent_name=agent.name, status="failed", error=str(e))
                results.append(error_result)
                if agent.critical:
                    logger.error(f"Critical agent {agent.name} failed: {e}")
                    break
                else:
                    logger.warning(f"Non-critical agent {agent.name} failed: {e}")

    return results
