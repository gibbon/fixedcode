import asyncio
import logging
import json
import anthropic
from fastapi import FastAPI{{#if hasAuth}}, Depends{{/if}}
from pydantic import BaseModel
from .settings import settings
{{#each tools}}
from .tools.{{this.name.snake}}_tools import {{this.name.snake}}_tool_def, handle_{{this.name.snake}}
{{/each}}
{{#if hasAuth}}
from .middleware.auth.middleware import require_auth
{{/if}}
{{#if hasCorrelationId}}
from .middleware.correlation_id import CorrelationIdMiddleware
{{/if}}
{{#if hasFeatureToggles}}
from .middleware.feature_toggles import FeatureToggleMiddleware
{{/if}}

logger = logging.getLogger(__name__)

app = FastAPI(title="{{serviceName.pascal}}")

{{#if hasCorrelationId}}
app.add_middleware(CorrelationIdMiddleware)
{{/if}}
{{#if hasFeatureToggles}}
app.add_middleware(FeatureToggleMiddleware)
{{/if}}

AGENT_NAME = "{{serviceName.kebab}}"
SYSTEM_PROMPT = """{{prompt}}"""
MAX_TURNS = 10

TOOL_DEFS = [{{#each tools}}{{this.name.snake}}_tool_def{{#unless @last}}, {{/unless}}{{/each}}]
TOOL_HANDLERS = {
{{#each tools}}
    "{{this.name.snake}}": handle_{{this.name.snake}},
{{/each}}
}

client = anthropic.Anthropic()


class ChatMessage(BaseModel):
    message: str
    session_id: str | None = None


@app.get("/health")
async def health():
    return {"status": "ok", "agent": AGENT_NAME}


@app.post("/query")
async def query_endpoint(chat_message: ChatMessage{{#if hasAuth}}, auth=Depends(require_auth()){{/if}}):
    messages = [{"role": "user", "content": chat_message.message}]
    cycles = 0

    while cycles < MAX_TURNS:
        response = await asyncio.to_thread(
            client.messages.create,
            model=settings.anthropic_model_id,
            max_tokens=4096,
            system=SYSTEM_PROMPT,
            tools=TOOL_DEFS,
            messages=messages,
        )
        cycles += 1

        if response.stop_reason != "tool_use":
            output = next((b.text for b in response.content if b.type == "text"), "")
            return {"output": output, "status": "completed", "cycles": cycles, "agent": AGENT_NAME}

        tool_results = []
        for block in response.content:
            if block.type == "tool_use":
                handler = TOOL_HANDLERS.get(block.name)
                if handler:
                    result = handler(**block.input)
                    tool_results.append({"type": "tool_result", "tool_use_id": block.id, "content": str(result)})

        messages.append({"role": "assistant", "content": response.content})
        messages.append({"role": "user", "content": tool_results})

    return {"output": "Max turns reached", "status": "max_turns", "cycles": cycles, "agent": AGENT_NAME}
