# --- Structured JSON logging ---
_handler = logging.StreamHandler()
_handler.setFormatter(jsonlogger.JsonFormatter(
    fmt="%(asctime)s %(levelname)s %(name)s %(message)s",
    datefmt="%Y-%m-%dT%H:%M:%SZ",
))
logging.getLogger().addHandler(_handler)
logging.getLogger().setLevel(logging.INFO)

logger = logging.getLogger("agent.{{serviceName.snake}}")

app = FastAPI(title="{{serviceName.pascal}} Agent")

{{#if hasCorrelationId}}
app.add_middleware(CorrelationIdMiddleware)
{{/if}}
{{#if hasFeatureToggles}}
app.add_middleware(FeatureToggleMiddleware)
{{/if}}

AGENT_NAME = "{{serviceName.pascal}}"
SYSTEM_PROMPT = """You are {{serviceName.pascal}}.

Use the tools available to you to complete the task. Call tools as needed.
When you have completed the task, provide a clear summary of what you did and the results.

{{prompt}}""".strip()
MAX_TURNS = 10
CONTEXT_WINDOW = 40
TOOLS = [{{#each tools}}{{this.name.snake}}_tool{{#unless @last}}, {{/unless}}{{/each}}]


# --- Request validation ---
class ChatMessage(BaseModel):
    message: str = Field(..., min_length=1, max_length=50000)
    session_id: str = Field(default="default", min_length=1, max_length=50)
    auth_token: str | None = None

    @field_validator("session_id")
    @classmethod
    def validate_session_id(cls, v: str) -> str:
        if not re.match(r"^[a-zA-Z0-9_-]+$", v):
            raise ValueError("session_id must be alphanumeric with hyphens/underscores only")
        return v


@app.get("/health")
async def health():
    return {"status": "ok", "agent": AGENT_NAME}


@app.get("/report/{session_id}")
async def report(session_id: str):
    return get_agent_progress(session_id) or {"status": "idle"}


@app.post("/query")
async def query_endpoint(chat_message: ChatMessage{{#if hasAuth}}, auth=Depends(require_auth()){{/if}}):
    result = await asyncio.to_thread(
        query_agent,
        agent_name=AGENT_NAME,
        tools=TOOLS,
        system_prompt=SYSTEM_PROMPT,
        max_turns=MAX_TURNS,
        context_window=CONTEXT_WINDOW,
        input_text=chat_message.message,
        session_id=chat_message.session_id,
        auth_token=chat_message.auth_token,
    )
    return result
{{#if streaming}}


@app.post("/stream")
async def stream_endpoint(chat_message: ChatMessage{{#if hasAuth}}, auth=Depends(require_auth()){{/if}}):
    from .shared import create_agent
    from fastapi.responses import StreamingResponse

    async def generate():
        agent = create_agent(
            tools=TOOLS,
            system_prompt=SYSTEM_PROMPT,
            context_window=CONTEXT_WINDOW,
            session_id=chat_message.session_id,
        )
        response = agent.stream_async(chat_message.message)
        async for event in response:
            if hasattr(event, "data"):
                yield event.data

    return StreamingResponse(generate(), media_type="text/event-stream")
{{/if}}


# --- Interactive CLI mode ---
def _chat_loop():
    print(f"\n{AGENT_NAME} Agent")
    print("  Type 'quit' to exit.\n")

    agent = create_agent(tools=TOOLS, system_prompt=SYSTEM_PROMPT, context_window=CONTEXT_WINDOW)

    while True:
        try:
            question = input("You: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nBye!")
            break
        if not question or question.lower() in ("quit", "exit", "q"):
            print("Bye!")
            break
        result = agent(question)
        print(f"\nAgent: {result}\n")
        agent.messages = []


if __name__ == "__main__":
    from .shared import create_agent
    logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(name)s: %(message)s", datefmt="%H:%M:%S")
    _chat_loop()
