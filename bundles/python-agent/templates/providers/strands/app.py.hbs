import asyncio
import logging
from fastapi import FastAPI{{#if hasAuth}}, Depends{{/if}}
from pydantic import BaseModel
from .shared import query_agent
from .settings import settings
{{#each tools}}
from .tools.{{this.name.snake}}_tools import {{this.name.snake}}_tool
{{/each}}
{{#if hasAuth}}
from .middleware.auth.middleware import require_auth
{{/if}}
{{#if hasCorrelationId}}
from .middleware.correlation_id import CorrelationIdMiddleware
{{/if}}
{{#if hasFeatureToggles}}
from .middleware.feature_toggles import FeatureToggleMiddleware
{{/if}}

logger = logging.getLogger(__name__)

app = FastAPI(title="{{serviceName.pascal}}")

{{#if hasCorrelationId}}
app.add_middleware(CorrelationIdMiddleware)
{{/if}}
{{#if hasFeatureToggles}}
app.add_middleware(FeatureToggleMiddleware)
{{/if}}

AGENT_NAME = "{{serviceName.kebab}}"
SYSTEM_PROMPT = """{{prompt}}"""
MAX_TURNS = 10
CONTEXT_WINDOW = 40
TOOLS = [{{#each tools}}{{this.name.snake}}_tool{{#unless @last}}, {{/unless}}{{/each}}]


class ChatMessage(BaseModel):
    message: str
    session_id: str | None = None


@app.get("/health")
async def health():
    return {"status": "ok", "agent": AGENT_NAME}


@app.post("/query")
async def query_endpoint(chat_message: ChatMessage{{#if hasAuth}}, auth=Depends(require_auth()){{/if}}):
    result = await asyncio.to_thread(
        query_agent,
        agent_name=AGENT_NAME,
        tools=TOOLS,
        system_prompt=SYSTEM_PROMPT,
        max_turns=MAX_TURNS,
        context_window=CONTEXT_WINDOW,
        input_text=chat_message.message,
        session_id=chat_message.session_id,
    )
    return result
{{#if streaming}}


@app.post("/stream")
async def stream_endpoint(chat_message: ChatMessage{{#if hasAuth}}, auth=Depends(require_auth()){{/if}}):
    from .shared import create_agent
    from fastapi.responses import StreamingResponse

    async def generate():
        agent = create_agent(
            tools=TOOLS,
            system_prompt=SYSTEM_PROMPT,
            context_window=CONTEXT_WINDOW,
            session_id=chat_message.session_id,
        )
        response = agent.stream_async(chat_message.message)
        async for event in response:
            if hasattr(event, "data"):
                yield event.data

    return StreamingResponse(generate(), media_type="text/event-stream")
{{/if}}
