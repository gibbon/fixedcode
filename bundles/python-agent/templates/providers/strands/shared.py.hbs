from .settings import settings

logger = logging.getLogger(__name__)


# --- Agent Progress Store ---
_progress: dict[str, dict] = {}
_progress_lock = threading.Lock()


def get_agent_progress(session_id: str) -> dict | None:
    with _progress_lock:
        return {k: v.copy() for k, v in _progress[session_id].items()} if session_id in _progress else None


def _set_session_context(session_id: str, agent_name: str):
    with _progress_lock:
        if session_id not in _progress:
            _progress[session_id] = {}
        _progress[session_id][agent_name] = {"status": "running", "tools": []}


# --- Cost estimation (per 1M tokens) ---
_MODEL_PRICING = {
    "claude-sonnet-4": {"input": 3.00, "output": 15.00},
    "claude-haiku": {"input": 0.80, "output": 4.00},
    "claude-opus": {"input": 15.00, "output": 75.00},
    "gpt-4o": {"input": 2.50, "output": 10.00},
    "gpt-4o-mini": {"input": 0.15, "output": 0.60},
}


def estimate_cost(model_id: str, input_tokens: int, output_tokens: int) -> float:
    mid = (model_id or "").lower()
    for pattern, prices in _MODEL_PRICING.items():
        if pattern in mid:
            return (input_tokens * prices["input"] + output_tokens * prices["output"]) / 1_000_000
    return 0.0


def _get_model_id() -> str:
    provider = os.getenv("LLM_PROVIDER", "bedrock").lower()
    env_key = {"bedrock": "BEDROCK_MODEL_ID", "anthropic": "ANTHROPIC_MODEL_ID", "openai": "OPENAI_MODEL_ID", "ollama": "OLLAMA_MODEL_ID"}.get(provider, "")
    return os.getenv("LLM_MODEL_ID") or os.getenv(env_key) or ""


def _create_model():
    provider = os.getenv("LLM_PROVIDER", "bedrock").lower()
    if provider == "bedrock":
        from strands.models.bedrock import BedrockModel
        model_id = os.getenv("LLM_MODEL_ID") or os.getenv("BEDROCK_MODEL_ID")
        region = os.getenv("BEDROCK_REGION")
        if not model_id:
            raise ValueError("BEDROCK_MODEL_ID or LLM_MODEL_ID required")
        if not region:
            raise ValueError("BEDROCK_REGION required")
        return BedrockModel(model_id=model_id, region_name=region)
    elif provider == "anthropic":
        from strands.models.anthropic import AnthropicModel
        model_id = os.getenv("LLM_MODEL_ID") or os.getenv("ANTHROPIC_MODEL_ID")
        return AnthropicModel(model_id=model_id)
    elif provider == "openai":
        from strands.models.openai import OpenAIModel
        model_id = os.getenv("LLM_MODEL_ID") or os.getenv("OPENAI_MODEL_ID")
        return OpenAIModel(model_id=model_id)
    elif provider == "ollama":
        from strands.models.ollama import OllamaModel
        model_id = os.getenv("LLM_MODEL_ID") or os.getenv("OLLAMA_MODEL_ID") or "llama3"
        host = os.getenv("OLLAMA_HOST", "http://localhost:11434")
        return OllamaModel(model_id=model_id, host=host)
    raise ValueError(f"Unsupported LLM provider: {provider!r}")


def create_agent(*, tools, system_prompt, context_window, session_id=None, auth_token=None):
    model = _create_model()
    conversation_manager = SlidingWindowConversationManager(window_size=context_window)

    kwargs = {
        "model": model,
        "tools": tools,
        "system_prompt": system_prompt,
        "conversation_manager": conversation_manager,
    }

    if auth_token:
        kwargs["state"] = {"auth_token": auth_token}
{{#if session.hasSession}}

    if session_id:
        kwargs["session_manager"] = _create_session_manager(session_id)
{{/if}}

    return Agent(**kwargs)


def query_agent(*, agent_name, tools, system_prompt, max_turns, context_window, input_text, session_id=None, auth_token=None):
    if session_id:
        _set_session_context(session_id, agent_name)

    agent = create_agent(
        tools=tools,
        system_prompt=system_prompt,
        context_window=context_window,
        session_id=session_id,
        auth_token=auth_token,
    )

    result = agent(input_text)
    cycles = 1

    while cycles < max_turns and result.state.last_invocation_had_tool_use:
        result = agent("Continue executing the plan.")
        cycles += 1

    # Collect usage metrics
    model_id = _get_model_id()
    usage = getattr(result, "usage", None)
    input_tokens = getattr(usage, "input_tokens", 0) if usage else 0
    output_tokens = getattr(usage, "output_tokens", 0) if usage else 0

    response = {
        "output": str(result),
        "status": "completed",
        "cycles": cycles,
        "agent": agent_name,
        "usage": {
            "input_tokens": input_tokens,
            "output_tokens": output_tokens,
            "total_tokens": input_tokens + output_tokens,
        },
        "metrics": {
            "model_id": model_id,
            "estimated_cost_usd": estimate_cost(model_id, input_tokens, output_tokens),
        },
    }

    if session_id:
        with _progress_lock:
            if session_id in _progress and agent_name in _progress[session_id]:
                _progress[session_id][agent_name]["status"] = "completed"

    return response
{{#if session.hasSession}}


def _create_session_manager(session_id: str):
    env = settings.app_environment.lower()
{{#if session.sessionDevFile}}

    if env in ("dev", "local"):
        return FileSessionManager(session_id=session_id, storage_dir="./sessions")
{{/if}}
{{#if session.sessionProdS3}}

    return S3SessionManager(
        session_id=session_id,
        bucket="{{session.prodBucket}}",
        boto_session=boto3.Session(region_name="ap-southeast-2"),
    )
{{else}}

    return FileSessionManager(session_id=session_id, storage_dir="./sessions")
{{/if}}
{{/if}}
