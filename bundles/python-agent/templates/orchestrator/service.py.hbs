"""Orchestrator service — session management and agent triggering."""
import asyncio
import logging
import uuid
from datetime import datetime, timezone

from .context import create_context_store
from .discovery import discover_agents
from .routing import _accumulate_usage, route
from .schemas import AgentResult, SessionReport, SessionStatus, TokenUsage

logger = logging.getLogger(__name__)

class OrchestratorService:
    def __init__(self):
        self._context_store = create_context_store()
        self._sessions: dict[str, dict] = {}

    def create_session(self, input_text: str, file_data: dict | None = None,
                       subscriber_id: str | None = None, metadata: dict | None = None,
                       auth_token: str | None = None) -> str:
        session_id = str(uuid.uuid4())
        agents = discover_agents()
        self._sessions[session_id] = {
            "input": input_text, "file": file_data, "subscriber_id": subscriber_id,
            "metadata": metadata, "auth_token": auth_token,
            "status": SessionStatus.RUNNING,
            "agents": agents, "agent_names": [a.name for a in agents],
            "results": [], "created_at": datetime.now(timezone.utc),
        }
        logger.info("Session %s created with agents: %s", session_id, [a.name for a in agents])
        return session_id

    async def process_session(self, session_id: str):
        session = self._sessions.get(session_id)
        if not session:
            return

        try:
            def on_complete(result):
                session["results"].append(result)

            results = await route(
                agents=session["agents"], input_text=session["input"],
                session_id=session_id, context_store=self._context_store,
                file_data=session.get("file"), subscriber_id=session.get("subscriber_id"),
                auth_token=session.get("auth_token"), on_agent_complete=on_complete,
            )
            session["results"] = results
            session["status"] = SessionStatus.COMPLETED
            session["completed_at"] = datetime.now(timezone.utc)
        except Exception as e:
            logger.error("Session %s failed: %s", session_id, e)
            session["status"] = SessionStatus.FAILED
            session["completed_at"] = datetime.now(timezone.utc)

    async def get_report(self, session_id: str) -> SessionReport:
        session = self._sessions.get(session_id)
        if not session:
            raise ValueError(f"Session {session_id} not found")

        results = session.get("results", [])
        total_usage = _accumulate_usage(results) if results else None
        completed_at = session.get("completed_at")
        created_at = session["created_at"]
        duration_ms = int((completed_at - created_at).total_seconds() * 1000) if completed_at else None

        return SessionReport(
            session_id=session_id, status=session["status"],
            routing_mode="{{routing}}",
            agent_results=results, total_usage=total_usage,
            created_at=created_at, completed_at=completed_at,
            total_duration_ms=duration_ms,
        )
