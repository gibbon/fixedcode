"""Agent discovery — checks which agents are available."""
import logging
import httpx
from dataclasses import dataclass

logger = logging.getLogger(__name__)

@dataclass
class AgentInfo:
    name: str
    url: str
    critical: bool = True

CONFIGURED_AGENTS: list[AgentInfo] = [
{{#each agents}}
    AgentInfo(name="{{this.name.pascal}}", url="http://localhost:{{@root.port}}/{{this.name.kebab}}", critical={{#if this.critical}}True{{else}}False{{/if}}),
{{/each}}
]

def discover_agents() -> list[AgentInfo]:
    return list(CONFIGURED_AGENTS)

async def check_agent_health(agent: AgentInfo) -> bool:
    try:
        async with httpx.AsyncClient(timeout=5) as client:
            r = await client.get(f"{agent.url}/health")
            return r.status_code == 200
    except Exception:
        return False
