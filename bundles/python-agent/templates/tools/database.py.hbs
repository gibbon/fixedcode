import json
import os
import psycopg2
from psycopg2.extras import RealDictCursor
from strands import tool


def _is_read_only(query: str) -> bool:
    q = query.strip().upper()
    return q.startswith("SELECT") or q.startswith("WITH") or q.startswith("EXPLAIN")


@tool
def {{tool.name.snake}}_tool(database_name: str, query: str, limit: int = 100) -> str:
    """Query database (read-only). Available databases: {{#each tool.config.databases}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}"""
    if not _is_read_only(query):
        return json.dumps({"error": "Read-only mode: only SELECT queries allowed"})

    host = os.getenv(f"DB_{database_name.upper()}_HOST", "localhost")
    port = int(os.getenv(f"DB_{database_name.upper()}_PORT", "5432"))
    db = os.getenv(f"DB_{database_name.upper()}_NAME", database_name)
    user = os.getenv(f"DB_{database_name.upper()}_USER", "postgres")
    password = os.getenv(f"DB_{database_name.upper()}_PASSWORD", "")

    try:
        conn = psycopg2.connect(host=host, port=port, database=db, user=user, password=password)
        with conn.cursor(cursor_factory=RealDictCursor) as cur:
            cur.execute(query)
            rows = [dict(r) for r in cur.fetchmany(limit)]
        conn.close()
        return json.dumps({"success": True, "row_count": len(rows), "data": rows}, default=str)
    except Exception as e:
        return json.dumps({"success": False, "error": str(e)})
