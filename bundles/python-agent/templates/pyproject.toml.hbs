[project]
name = "{{serviceName.kebab}}"
version = "0.1.0"
requires-python = ">=3.11"
dependencies = [
    "fastapi>=0.110.0",
    "uvicorn>=0.27.0",
    "pydantic-settings>=2.0.0",
    "python-dotenv>=1.0.0",
    "python-json-logger>=3.0.0",
    "{{providerDependency}}",
{{#if hasAuth}}
    "PyJWT>=2.8.0",
    "cryptography>=42.0.0",
{{/if}}
{{#if hasFeatureToggles}}
    "UnleashClient>=5.0.0",
{{/if}}
{{#if session.sessionProdS3}}
    "boto3>=1.34.0",
{{/if}}
{{#each tools}}
{{#if (eq this.type "http")}}
    "requests>=2.31.0",
{{/if}}
{{#if (eq this.type "database")}}
    "psycopg2-binary>=2.9.0",
{{/if}}
{{#if (eq this.type "mcp")}}
    "mcp>=1.0.0",
{{/if}}
{{/each}}
    "httpx>=0.27.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0.0",
    "pytest-asyncio>=0.24.0",
    "httpx>=0.27.0",
]
