{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["package", "aggregates"],
  "properties": {
    "package": {
      "type": "string",
      "description": "Java package name for the generated code"
    },
    "aggregates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "attributes"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$"
          },
          "attributes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9]*$"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "uuid",
                    "string",
                    "int",
                    "long",
                    "boolean",
                    "decimal",
                    "date",
                    "datetime",
                    "object"
                  ]
                },
                "required": {
                  "type": "boolean"
                },
                "identity": {
                  "type": "boolean"
                },
                "default": {
                  "type": "string"
                }
              }
            }
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "params", "emits"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "params": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string" },
                      "required": { "type": "boolean" }
                    }
                  }
                },
                "emits": {
                  "type": "string"
                }
              }
            }
          },
          "queries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "returns"],
              "properties": {
                "name": { "type": "string" },
                "returns": {
                  "type": "string",
                  "enum": ["single", "list"]
                },
                "filters": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "fields"],
              "properties": {
                "name": { "type": "string" },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
