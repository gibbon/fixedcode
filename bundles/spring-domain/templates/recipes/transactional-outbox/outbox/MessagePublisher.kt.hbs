package {{packageDot}}.outbox

/**
 * Generated by fixedcode (recipe: transactional-outbox).
 *
 * Stable contract for publishing an outbox row to whatever downstream message
 * bus (Kafka / SQS / NATS / Pub/Sub / RabbitMQ) the deployment uses. The relay
 * calls this for each fetched row; the implementation is the documented
 * extension point — see [NoopMessagePublisher].
 *
 * Implementations MUST throw on failure (any exception). The relay catches it,
 * increments the attempts counter, and tries again on the next poll.
 */
fun interface MessagePublisher {
    /**
     * Publish a single event. The `topic` is taken from `DomainEvent.getTopicName()`;
     * pass it through to your bus or use it as a Kafka topic, SQS queue url, etc.
     * The `payload` is the JSON-serialised event body — wire it as the message
     * value as-is (most consumers expect a JSON envelope).
     */
    fun publish(event: OutboxEvent)
}
