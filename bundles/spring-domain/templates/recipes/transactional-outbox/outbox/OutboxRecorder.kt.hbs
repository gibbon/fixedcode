package {{packageDot}}.outbox

import com.fasterxml.jackson.databind.ObjectMapper
import {{packageDot}}.domain.shared.DomainEvent
import org.springframework.stereotype.Component
import org.springframework.transaction.annotation.Propagation
import org.springframework.transaction.annotation.Transactional
import java.util.UUID

/**
 * Generated by fixedcode (recipe: transactional-outbox).
 *
 * Call this from your application/business service inside the same transaction
 * that persists the aggregate, e.g.:
 *
 *   class DefaultOrderBusinessService(
 *       private val repo: OrderWriteRepository,
 *       private val outbox: OutboxRecorder,
 *   ) : OrderBusinessService {
 *       @Transactional
 *       override fun create(cmd: CreateOrderCommand): Order {
 *           val (order, events) = Order.create(cmd)
 *           repo.save(order)
 *           events.forEach(outbox::record)   // outbox row(s) committed atomically
 *           return order
 *       }
 *   }
 *
 * The relay then publishes asynchronously — your write path stays fast and your
 * downstream sink (Kafka/SQS/etc.) can be down without losing events.
 */
@Component
class OutboxRecorder(
    private val repository: OutboxRepository,
    private val objectMapper: ObjectMapper,
) {
    /**
     * Record a [DomainEvent] for asynchronous publication. Joins the caller's
     * transaction (`MANDATORY`) — recording outside a transaction is a bug,
     * because the row needs to commit atomically with the aggregate write.
     */
    @Transactional(propagation = Propagation.MANDATORY)
    fun record(event: DomainEvent, aggregateType: String? = null) {
        val payload = objectMapper.writeValueAsString(event)
        repository.save(
            OutboxEvent(
                id = UUID.randomUUID(),
                aggregateType = aggregateType ?: deriveAggregateType(event),
                aggregateId = event.getRootAggregateId(),
                eventType = event.eventType,
                topic = event.getTopicName(),
                payload = payload,
                occurredAt = event.occurredAt,
            ),
        )
    }

    /**
     * Best-effort aggregate-type label when the caller doesn't pass one. Pulls
     * the simple class name and strips an `Event`/`*Event` suffix when present
     * (e.g. `OrderCreated` → `Order`, but `OrderUpdated` stays as
     * `OrderUpdated` — pass [aggregateType] explicitly when you care).
     */
    private fun deriveAggregateType(event: DomainEvent): String {
        val simple = event::class.simpleName ?: "Unknown"
        val createdSuffix = "Created"
        val updatedSuffix = "Updated"
        val deletedSuffix = "Deleted"
        return when {
            simple.endsWith(createdSuffix) -> simple.removeSuffix(createdSuffix)
            simple.endsWith(updatedSuffix) -> simple.removeSuffix(updatedSuffix)
            simple.endsWith(deletedSuffix) -> simple.removeSuffix(deletedSuffix)
            else -> simple
        }
    }
}
