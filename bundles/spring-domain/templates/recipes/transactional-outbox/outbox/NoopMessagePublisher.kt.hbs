import mu.KotlinLogging
import org.springframework.stereotype.Component

private val log = KotlinLogging.logger {}

/**
 * Generated by fixedcode (recipe: transactional-outbox) — extension point.
 *
 * Default [MessagePublisher] that just logs the event. Replace this class with
 * a real publisher when you wire your bus. Examples:
 *
 *   // Kafka
 *   @Component
 *   class KafkaMessagePublisher(
 *       private val template: KafkaTemplate<String, String>,
 *   ) : MessagePublisher {
 *       override fun publish(event: OutboxEvent) {
 *           template.send(event.topic, event.aggregateId.toString(), event.payload).get()
