@Component
class NoopMessagePublisher : MessagePublisher {
    override fun publish(event: OutboxEvent) {
        log.info {
            "outbox publish (no-op) topic=${event.topic} eventType=${event.eventType} " +
                "aggregateId=${event.aggregateId} attempts=${event.attempts}"
        }
    }
}
