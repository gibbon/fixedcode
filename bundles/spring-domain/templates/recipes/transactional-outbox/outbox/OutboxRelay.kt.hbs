package {{packageDot}}.outbox

import mu.KotlinLogging
import org.springframework.data.domain.PageRequest
import org.springframework.scheduling.annotation.Scheduled
import org.springframework.stereotype.Component
import org.springframework.transaction.annotation.Propagation
import org.springframework.transaction.annotation.Transactional
import java.time.Instant

private val log = KotlinLogging.logger {}

/**
 * Generated by fixedcode (recipe: transactional-outbox).
 *
 * Drains the outbox on a fixed cadence. One pass per tick:
 *   1. Claim a batch via `FOR UPDATE` so concurrent instances don't both try
 *      to publish the same row.
 *   2. For each row: call [MessagePublisher.publish]. On success, mark
 *      `publishedAt = now`. On failure, bump `attempts` and stash the error.
 *   3. Save in the same transaction. Commit on tick boundary.
 *
 * Rows that hit `maxAttempts` are left untouched — operator inspection is
 * deliberately required (a poison-pill auto-discard policy is too easy to
 * misconfigure).
 */
@Component
class OutboxRelay(
    private val repository: OutboxRepository,
    private val publisher: MessagePublisher,
    private val properties: OutboxProperties,
) {

    @Scheduled(fixedDelayString = "{{springProp "app.outbox.poll-interval-ms" outbox.pollIntervalMs}}")
    @Transactional(propagation = Propagation.REQUIRES_NEW)
    fun drain() {
        val batch = repository.fetchUnpublishedBatch(
            properties.maxAttempts,
            PageRequest.of(0, properties.batchSize),
        )
        if (batch.isEmpty()) return
        log.debug { "outbox drain: ${batch.size} row(s)" }
        for (row in batch) {
            try {
                publisher.publish(row)
                row.publishedAt = Instant.now()
                row.lastError = null
            } catch (ex: Exception) {
                row.attempts += 1
                row.lastError = ex.message?.take(1024) ?: ex::class.simpleName
                log.warn(ex) {
                    "outbox publish failed id=${row.id} eventType=${row.eventType} " +
                        "attempts=${row.attempts}/${properties.maxAttempts}"
                }
            }
        }
        repository.saveAll(batch)
    }
}
