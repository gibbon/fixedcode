-- Generated by fixedcode (recipe: transactional-outbox).
-- Versioned at V099 to sit just below the V100+ range we reserve for app-level
-- recipe migrations on the BFF side, and clear of the V001..V099 range
-- spring-domain uses for aggregate tables — pick a higher number if your
-- aggregate set ever pushes past V099.

CREATE TABLE outbox_event (
    id              UUID         PRIMARY KEY,
    aggregate_type  VARCHAR(255) NOT NULL,
    aggregate_id    UUID         NOT NULL,
    event_type      VARCHAR(128) NOT NULL,
    topic           VARCHAR(128) NOT NULL,
    payload         JSONB        NOT NULL,
    occurred_at     TIMESTAMPTZ  NOT NULL,
    published_at    TIMESTAMPTZ,
    attempts        INTEGER      NOT NULL DEFAULT 0,
    last_error      VARCHAR(1024),
    version         BIGINT       NOT NULL DEFAULT 0
);

-- The relay's hot path: scan unpublished rows oldest-first.
CREATE INDEX idx_outbox_event_unpublished
    ON outbox_event (occurred_at ASC)
    WHERE published_at IS NULL;

-- Per-aggregate inspection.
CREATE INDEX idx_outbox_event_aggregate
    ON outbox_event (aggregate_type, aggregate_id, occurred_at DESC);
