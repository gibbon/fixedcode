{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["boundedContext", "service", "aggregates"],
  "properties": {
    "boundedContext": { "type": "string" },
    "service": {
      "type": "object",
      "required": ["package"],
      "properties": {
        "port": { "type": "number" },
        "package": { "type": "string" }
      }
    },
    "aggregates": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/aggregate" }
    },
    "remote_aggregates": {
      "type": "object"
    }
  },
  "definitions": {
    "aggregate": {
      "type": "object",
      "properties": {
        "plural": { "type": "string" },
        "attributes": { "type": "object" },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "body": { "type": "array", "items": { "type": "string" } },
              "path": { "type": "array", "items": { "type": "string" } },
              "query": { "type": "array", "items": { "type": "string" } },
              "emits": { "type": "string" },
              "returns": { "type": "string" }
            }
          }
        },
        "queries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "returns"],
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "array", "items": { "type": "string" } },
              "query": { "type": "array", "items": { "type": "string" } },
              "returns": { "type": "string" }
            }
          }
        },
        "events": { "type": "object" },
        "enumDefaults": { "type": "object" },
        "entities": { "type": "object" }
      }
    }
  }
}
