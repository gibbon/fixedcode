{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["boundedContext", "service", "aggregates"],
  "properties": {
    "boundedContext": { "type": "string" },
    "service": {
      "type": "object",
      "required": ["package"],
      "properties": {
        "port": { "type": "number" },
        "package": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9.]*$" }
      }
    },
    "aggregates": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/aggregate" },
      "propertyNames": { "pattern": "^[A-Z][a-zA-Z0-9]*$" }
    },
    "remote_aggregates": {
      "type": "object"
    },
    "recipes": {
      "type": "array",
      "description": "Named feature recipes to layer on top of the generated domain code",
      "items": { "type": "string", "enum": ["transactional-outbox"] },
      "default": []
    },
    "outbox": {
      "type": "object",
      "description": "Configuration for the transactional-outbox recipe (no effect unless the recipe is enabled).",
      "properties": {
        "pollIntervalMs": {
          "type": "integer",
          "minimum": 100,
          "default": 5000,
          "description": "How often the OutboxRelay polls for unpublished events"
        },
        "batchSize": {
          "type": "integer",
          "minimum": 1,
          "default": 100,
          "description": "Max rows fetched per poll"
        },
        "maxAttempts": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "After this many failed publish attempts, the row is left for an operator to inspect"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "aggregate": {
      "type": "object",
      "required": ["attributes"],
      "properties": {
        "plural": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
        "attributes": { "type": "object" },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "body": { "type": "array", "items": { "type": "string" } },
              "path": { "type": "array", "items": { "type": "string" } },
              "query": { "type": "array", "items": { "type": "string" } },
              "emits": { "type": "string" },
              "returns": { "type": "string" }
            }
          }
        },
        "queries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "returns"],
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "array", "items": { "type": "string" } },
              "query": { "type": "array", "items": { "type": "string" } },
              "returns": { "type": "string" }
            }
          }
        },
        "events": { "type": "object" },
        "enumDefaults": { "type": "object" },
        "entities": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/aggregate" },
          "propertyNames": { "pattern": "^[A-Z][a-zA-Z0-9]*$" }
        }
      }
    }
  }
}
