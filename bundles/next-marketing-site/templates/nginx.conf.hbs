server {
  listen 80;
  server_name _;
  root /usr/share/nginx/html;
  index index.html;

  # Next.js static export uses trailingSlash:true — serve <slug>/index.html naturally.
  location / {
    try_files $uri $uri/ $uri/index.html /index.html =404;
  }

  # Long cache for hashed Next.js assets.
  location /_next/static/ {
    expires 1y;
    add_header Cache-Control "public, immutable";
  }
}
