{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["appName"],
  "properties": {
    "appName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "App name in kebab-case"
    },
    "port": {
      "type": "integer",
      "default": 5173
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "name"],
        "properties": {
          "path": { "type": "string" },
          "name": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "router": {
          "enum": ["tanstack", "reactrouter", "none"],
          "default": "tanstack"
        },
        "api": { "type": "boolean", "default": true },
        "apiBaseUrl": { "type": "string" },
        "auth": {
          "enum": ["supabase", "clerk", "none"],
          "default": "none"
        },
        "docker": { "type": "boolean", "default": false },
        "tailwind": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "recipes": {
      "type": "array",
      "description": "Named feature recipes to include in the generated app",
      "items": {
        "type": "string",
        "enum": [
          "image-upload",
          "admin-screen",
          "users-management",
          "pricing-page",
          "dashboard",
          "pagination-list-ui"
        ]
      },
      "default": []
    },
    "paginationListUi": {
      "type": "object",
      "description": "Configuration for the pagination-list-ui recipe (no effect unless the recipe is enabled). Designed to consume the `pagination-filter-sort` BFF wire format (`?page&size&sort&filter` → `PageResponse<T>`).",
      "properties": {
        "defaultPageSize": {
          "type": "integer",
          "minimum": 1,
          "default": 20,
          "description": "Initial `size` requested by the hook"
        },
        "pageSizeOptions": {
          "type": "array",
          "description": "Choices offered by the page-size dropdown in the Pagination component",
          "items": { "type": "integer", "minimum": 1 },
          "default": [10, 20, 50, 100]
        }
      },
      "additionalProperties": false
    },
    "usersManagement": {
      "type": "object",
      "description": "Configuration for the users-management recipe (no effect unless users-management is enabled)",
      "properties": {
        "signInPath": { "type": "string", "default": "/sign-in" },
        "signUpPath": { "type": "string", "default": "/sign-up" },
        "afterSignInPath": { "type": "string", "default": "/" }
      },
      "additionalProperties": false
    },
    "imageUpload": {
      "type": "object",
      "description": "Configuration for the image-upload recipe (no effect unless image-upload is enabled)",
      "properties": {
        "apiPath": { "type": "string", "default": "/images" }
      },
      "additionalProperties": false
    },
    "adminScreen": {
      "type": "object",
      "description": "Configuration for the admin-screen recipe (no effect unless admin-screen is enabled)",
      "properties": {
        "domainSpec": {
          "type": "string",
          "description": "Path to a sibling spring-domain spec YAML, resolved relative to process.cwd() (i.e. the directory you ran fixedcode from)."
        },
        "basePath": { "type": "string", "default": "/admin" },
        "apiBaseUrl": { "type": "string", "default": "" }
      },
      "additionalProperties": false
    },
    "dashboard": {
      "type": "object",
      "description": "Configuration for the dashboard recipe (no effect unless dashboard is enabled)",
      "properties": {
        "title": { "type": "string", "default": "Dashboard" },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "endpoint"],
            "properties": {
              "name": { "type": "string" },
              "endpoint": { "type": "string" },
              "units": { "type": "string" },
              "format": {
                "type": "string",
                "enum": ["number", "currency", "percent"],
                "default": "number"
              }
            },
            "additionalProperties": false
          }
        },
        "timeRanges": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["7d", "30d", "90d"]
        }
      },
      "additionalProperties": false
    },
    "pricing": {
      "type": "object",
      "description": "Pricing tiers rendered by the pricing-page recipe (no effect unless pricing-page is enabled)",
      "properties": {
        "headline": { "type": "string", "default": "Pricing" },
        "subhead": { "type": "string" },
        "tiers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "price"],
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "string" },
              "period": { "type": "string" },
              "audience": { "type": "string" },
              "description": { "type": "string" },
              "features": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "included": { "type": "boolean", "default": true }
                  },
                  "additionalProperties": false
                }
              },
              "ctaText": { "type": "string", "default": "Get started" },
              "ctaHref": { "type": "string" },
              "highlight": { "type": "boolean", "default": false }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
