{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["appName"],
  "properties": {
    "appName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "App name in kebab-case"
    },
    "port": {
      "type": "integer",
      "default": 5173
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "name"],
        "properties": {
          "path": { "type": "string" },
          "name": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "router": {
          "enum": ["tanstack", "reactrouter", "none"],
          "default": "tanstack"
        },
        "api": { "type": "boolean", "default": true },
        "apiBaseUrl": { "type": "string" },
        "auth": {
          "enum": ["supabase", "clerk", "none"],
          "default": "none"
        },
        "docker": { "type": "boolean", "default": false },
        "tailwind": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
