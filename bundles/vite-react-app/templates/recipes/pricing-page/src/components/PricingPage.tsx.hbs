// Generated by fixedcode (recipe: pricing-page) — extension point.
// Renders the pricing tiers from spec.pricing. Customize markup/styling here.
// Tier data is inlined at generation time; re-run `fixedcode generate` to refresh.

interface PricingFeature {
  text: string;
  included: boolean;
}

interface PricingTier {
  name: string;
  slug: string;
  price: string;
  period: string;
  audience: string;
  description: string;
  features: PricingFeature[];
  ctaText: string;
  ctaHref: string;
  highlight: boolean;
}

const HEADLINE = {{json pricing.headline}};
{{#if pricing.hasSubhead}}const SUBHEAD: string | null = {{json pricing.subhead}};
{{else}}const SUBHEAD: string | null = null;
{{/if}}
const TIERS: PricingTier[] = [
{{#each pricing.tiers}}  {
    name: {{json name}},
    slug: {{json slug}},
    price: {{json price}},
    period: {{json period}},
    audience: {{json audience}},
    description: {{json description}},
    features: [
{{#each features}}      { text: {{json text}}, included: {{included}} },
{{/each}}    ],
    ctaText: {{json ctaText}},
    ctaHref: {{json ctaHref}},
    highlight: {{highlight}},
  },
{{/each}}];

export interface PricingPageProps {
  /** Override the headline rendered above the tier grid. */
  headline?: string;
  /** Override the subhead rendered below the headline. */
  subhead?: string | null;
}

export default function PricingPage({ headline, subhead }: PricingPageProps = {}) {
  const resolvedHeadline = headline ?? HEADLINE;
  const resolvedSubhead = subhead === undefined ? SUBHEAD : subhead;

  return (
    <section className="mx-auto w-full max-w-6xl px-6 py-20">
      <header className="mb-14 text-center">
        <h1 className="text-3xl font-semibold tracking-tight sm:text-4xl">{resolvedHeadline}</h1>
        {resolvedSubhead ? (
          <p className="mx-auto mt-4 max-w-2xl text-base text-neutral-600">{resolvedSubhead}</p>
        ) : null}
      </header>

      <div className="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
        {TIERS.map((tier) => (
          <article
            key={tier.slug}
            className={
              'flex flex-col rounded-lg border bg-white p-6 ' +
              (tier.highlight
                ? 'border-neutral-900 shadow-sm ring-1 ring-neutral-900'
                : 'border-neutral-200')
            }
            data-tier={tier.slug}
            data-highlight={tier.highlight ? 'true' : 'false'}
          >
            {tier.highlight ? (
              <p className="mb-4 inline-flex w-fit items-center rounded-full border border-neutral-900 px-2 py-0.5 text-[11px] font-medium uppercase tracking-wider text-neutral-900">
                Most popular
              </p>
            ) : null}

            <header className="mb-6">
              <h2 className="text-lg font-semibold text-neutral-900">{tier.name}</h2>
              {tier.audience ? (
                <p className="mt-1 text-xs uppercase tracking-wide text-neutral-500">
                  {tier.audience}
                </p>
              ) : null}
            </header>

            <div className="mb-4 flex items-baseline gap-1">
              <span className="text-3xl font-semibold text-neutral-900">{tier.price}</span>
              {tier.period ? (
                <span className="text-sm text-neutral-500">{tier.period}</span>
              ) : null}
            </div>

            {tier.description ? (
              <p className="mb-6 text-sm text-neutral-600">{tier.description}</p>
            ) : null}

            <a
              href={tier.ctaHref}
              className={
                'mb-6 inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium transition-colors ' +
                (tier.highlight
                  ? 'bg-neutral-900 text-white hover:bg-neutral-800'
                  : 'border border-neutral-300 text-neutral-900 hover:bg-neutral-50')
              }
            >
              {tier.ctaText}
            </a>

            {tier.features.length > 0 ? (
              <ul className="mt-auto space-y-2 border-t border-neutral-200 pt-4 text-sm">
                {tier.features.map((feature) => (
                  <li
                    key={feature.text}
                    className={
                      'flex items-start gap-2 ' +
                      (feature.included ? 'text-neutral-700' : 'text-neutral-400 line-through')
                    }
                  >
                    <span aria-hidden className="mt-1 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-current" />
                    <span>{feature.text}</span>
                  </li>
                ))}
              </ul>
            ) : null}
          </article>
        ))}
      </div>
    </section>
  );
}
