// Generated by fixedcode (recipe: dashboard) — extension point.
// Page-level shell: title, time-range selector, stat grid, charts slot.
//
// Stat metadata is inlined at generation time from spec.dashboard.stats.
// Re-run `fixedcode generate` after editing the spec to refresh metadata.
//
// NOTE: This recipe deliberately does NOT bring in a charting library.
//       To add visualisations later, drop your favourite into the
//       <section data-slot="charts"> block below. Suggestions:
//         - Recharts   (npm i recharts)        — composable React charts
//         - Tremor     (npm i @tremor/react)   — opinionated dashboard kit
//         - Chart.js   (npm i chart.js react-chartjs-2)
//       Keep `fetchStat` for time-series data (extend the response shape) and
//       wire chart components per stat slug.

import { useEffect, useState, type ReactNode } from 'react';
import StatCard from './StatCard';
import { fetchStat, type StatFormat } from '../lib/dashboard';

interface StatMeta {
  name: string;
  slug: string;
  endpoint: string;
  units: string;
  format: StatFormat;
}

const TITLE = {{json dashboard.title}};
const TIME_RANGES: string[] = {{json dashboard.timeRanges}};
const DEFAULT_RANGE = {{json dashboard.defaultTimeRange}};
const STATS: StatMeta[] = [
{{#each dashboard.stats}}  { name: {{json name}}, slug: {{json slug}}, endpoint: {{json endpoint}}, units: {{json units}}, format: {{json format}} },
{{/each}}];

interface StatState {
  value: number | null;
  loading: boolean;
  error: string | null;
}

const initialState: StatState = { value: null, loading: true, error: null };

export interface DashboardLayoutProps {
  /** Optional content rendered in the charts slot (below the stat grid). */
  charts?: ReactNode;
}

export default function DashboardLayout({ charts }: DashboardLayoutProps = {}) {
  const [range, setRange] = useState<string>(DEFAULT_RANGE);
  const [statStates, setStatStates] = useState<Record<string, StatState>>(() =>
    Object.fromEntries(STATS.map((s) => [s.slug, initialState])),
  );

  useEffect(() => {
    let cancelled = false;
    setStatStates(Object.fromEntries(STATS.map((s) => [s.slug, initialState])));
    for (const stat of STATS) {
      fetchStat(stat.endpoint, range)
        .then((res) => {
          if (cancelled) return;
          setStatStates((prev) => ({
            ...prev,
            [stat.slug]: { value: res.value, loading: false, error: null },
          }));
        })
        .catch((err: unknown) => {
          if (cancelled) return;
          const message = err instanceof Error ? err.message : String(err);
          setStatStates((prev) => ({
            ...prev,
            [stat.slug]: { value: null, loading: false, error: message },
          }));
        });
    }
    return () => {
      cancelled = true;
    };
  }, [range]);

  return (
    <section className="mx-auto w-full max-w-7xl px-6 py-10">
      <header className="mb-8 flex flex-wrap items-end justify-between gap-4">
        <h1 className="text-2xl font-semibold tracking-tight text-neutral-900">{TITLE}</h1>
        {TIME_RANGES.length > 1 ? (
          <div
            role="tablist"
            aria-label="Time range"
            className="inline-flex rounded-md border border-neutral-200 bg-white p-0.5"
          >
            {TIME_RANGES.map((r) => {
              const active = r === range;
              return (
                <button
                  key={r}
                  type="button"
                  role="tab"
                  aria-selected={active}
                  onClick={() => setRange(r)}
                  className={
                    'rounded px-3 py-1 text-sm font-medium transition-colors ' +
                    (active
                      ? 'bg-neutral-900 text-white'
                      : 'text-neutral-600 hover:text-neutral-900')
                  }
                  data-range={r}
                  data-active={active ? 'true' : 'false'}
                >
                  {r}
                </button>
              );
            })}
          </div>
        ) : null}
      </header>

      <div
        className="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
        data-slot="stats"
      >
        {STATS.map((stat) => {
          const state = statStates[stat.slug] ?? initialState;
          return (
            <StatCard
              key={stat.slug}
              name={stat.name}
              value={state.value}
              units={stat.units || undefined}
              format={stat.format}
              loading={state.loading}
            />
          );
        })}
      </div>

      <section className="mt-10" data-slot="charts">
        {charts}
      </section>
    </section>
  );
}
