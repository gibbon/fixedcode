// Generated by fixedcode (recipe: users-management) — extension point.
//
// Holds the current user + token in React context. Refetches `me` on mount if
// a token is found in storage. Replace this with a Clerk/Auth0/Supabase
// provider by re-implementing the same `AuthContextValue` shape; the rest of
// the recipe (useAuth, RequireAuth, RequireRole) only depends on that shape.

import { createContext, useCallback, useEffect, useMemo, useRef, useState } from 'react';
import type { ReactNode } from 'react';
import { me, signIn as apiSignIn, signUp as apiSignUp } from '../lib/auth';
import type { SignInBody, SignUpBody, User } from '../lib/auth';
import { clearToken, loadToken, saveToken } from '../lib/auth-storage';

export interface AuthContextValue {
  user: User | null;
  token: string | null;
  isAuthenticated: boolean;
  isLoading: boolean;
  signIn: (body: SignInBody) => Promise<void>;
  signUp: (body: SignUpBody) => Promise<void>;
  signOut: () => void;
}

export const AuthContext = createContext<AuthContextValue | null>(null);

interface AuthProviderProps {
  children: ReactNode;
}

export function AuthProvider({ children }: AuthProviderProps) {
  const [user, setUser] = useState<User | null>(null);
  const [token, setToken] = useState<string | null>(() => loadToken());
  const [isLoading, setIsLoading] = useState<boolean>(() => loadToken() !== null);
  const initialized = useRef(false);

  // Hydrate `user` from `me` if we already have a token.
  useEffect(() => {
    if (initialized.current) return;
    initialized.current = true;
    const stored = loadToken();
    if (!stored) {
      setIsLoading(false);
      return;
    }
    me(stored)
      .then((u) => {
        setUser(u);
      })
      .catch(() => {
        // Stale or invalid token — clear it.
        clearToken();
        setToken(null);
      })
      .finally(() => {
        setIsLoading(false);
      });
  }, []);

  const handleSignIn = useCallback(async (body: SignInBody) => {
    const res = await apiSignIn(body);
    saveToken(res.token);
    setToken(res.token);
    setUser(res.user);
  }, []);

  const handleSignUp = useCallback(async (body: SignUpBody) => {
    const res = await apiSignUp(body);
    saveToken(res.token);
    setToken(res.token);
    setUser(res.user);
  }, []);

  const handleSignOut = useCallback(() => {
    clearToken();
    setToken(null);
    setUser(null);
  }, []);

  const value = useMemo<AuthContextValue>(
    () => ({
      user,
      token,
      isAuthenticated: user !== null,
      isLoading,
      signIn: handleSignIn,
      signUp: handleSignUp,
      signOut: handleSignOut,
    }),
    [user, token, isLoading, handleSignIn, handleSignUp, handleSignOut],
  );

  return <AuthContext.Provider value={value}>{children}</AuthContext.Provider>;
}
