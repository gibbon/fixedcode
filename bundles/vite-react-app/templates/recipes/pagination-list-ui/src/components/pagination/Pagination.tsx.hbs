// Generated by fixedcode (recipe: pagination-list-ui) — extension point.
// Pagination controls bound to a `PageResponse` + handlers from `usePagedList`.
// Customise markup freely; the props contract is stable.

import type { PageResponse } from '../../lib/pagination/types';

export interface PaginationProps<T> {
  data: PageResponse<T>;
  size: number;
  pageSizeOptions?: number[];
  onPageChange: (page: number) => void;
  onSizeChange?: (size: number) => void;
  /** Hide the page-size dropdown when no `onSizeChange` is provided. Default: true. */
  showSizeSelector?: boolean;
}

const DEFAULT_PAGE_SIZE_OPTIONS = {{{json paginationListUi.pageSizeOptions}}};

export default function Pagination<T>({
  data,
  size,
  pageSizeOptions = DEFAULT_PAGE_SIZE_OPTIONS,
  onPageChange,
  onSizeChange,
  showSizeSelector = true,
}: PaginationProps<T>) {
  if (data.totalElements === 0) {
    return null;
  }

  const start = data.page * data.size + 1;
  const end = data.page * data.size + data.numberOfElements;
  const showSize = showSizeSelector && onSizeChange !== undefined;

  return (
    <nav
      className="flex flex-wrap items-center justify-between gap-3 border-t border-neutral-200 px-4 py-3 text-sm"
      aria-label="Pagination"
    >
      <p className="text-neutral-600">
        Showing <span className="font-medium tabular-nums">{start}</span>
        &ndash;<span className="font-medium tabular-nums">{end}</span> of{' '}
        <span className="font-medium tabular-nums">{data.totalElements}</span>
      </p>

      <div className="flex items-center gap-2">
        {showSize ? (
          <label className="flex items-center gap-1.5 text-neutral-600">
            <span>Rows per page</span>
            <select
              className="rounded border border-neutral-300 bg-white px-2 py-1 text-sm"
              value={size}
              onChange={(e) => onSizeChange?.(Number(e.target.value))}
            >
              {pageSizeOptions.map((n) => (
                <option key={n} value={n}>
                  {n}
                </option>
              ))}
            </select>
          </label>
        ) : null}

        <button
          type="button"
          className="rounded border border-neutral-300 bg-white px-3 py-1 font-medium text-neutral-700 hover:bg-neutral-50 disabled:cursor-not-allowed disabled:opacity-50"
          onClick={() => onPageChange(data.page - 1)}
          disabled={!data.hasPrevious}
        >
          Previous
        </button>
        <span className="tabular-nums text-neutral-600">
          Page <span className="font-medium">{data.page + 1}</span> of{' '}
          <span className="font-medium">{Math.max(1, data.totalPages)}</span>
        </span>
        <button
          type="button"
          className="rounded border border-neutral-300 bg-white px-3 py-1 font-medium text-neutral-700 hover:bg-neutral-50 disabled:cursor-not-allowed disabled:opacity-50"
          onClick={() => onPageChange(data.page + 1)}
          disabled={!data.hasNext}
        >
          Next
        </button>
      </div>
    </nav>
  );
}
