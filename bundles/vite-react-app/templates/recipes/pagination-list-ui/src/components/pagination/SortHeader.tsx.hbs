// Generated by fixedcode (recipe: pagination-list-ui) — extension point.
// Clickable table-header cell that toggles a single sort key:
//   no-sort → ASC → DESC → no-sort
// Single-key (multi-key sorting is rare in admin UIs and noisier to express
// in markup). Customise markup freely; the props contract is stable.

import type { SortDirection, SortSpec } from '../../lib/pagination/types';

export interface SortHeaderProps {
  field: string;
  /** Visible label. Defaults to the field name. */
  label?: string;
  current: SortSpec[];
  onChange: (sort: SortSpec[]) => void;
  className?: string;
}

export default function SortHeader({
  field,
  label,
  current,
  onChange,
  className,
}: SortHeaderProps) {
  const active = current.find((s) => s.field === field);
  const direction: SortDirection | null = active?.direction ?? null;

  function nextDirection(): SortDirection | null {
    if (direction === null) return 'ASC';
    if (direction === 'ASC') return 'DESC';
    return null;
  }

  function handleClick() {
    const next = nextDirection();
    if (next === null) {
      onChange(current.filter((s) => s.field !== field));
    } else {
      onChange([{ field, direction: next }]);
    }
  }

  const ariaSort: 'ascending' | 'descending' | 'none' =
    direction === 'ASC' ? 'ascending' : direction === 'DESC' ? 'descending' : 'none';

  return (
    <th
      scope="col"
      aria-sort={ariaSort}
      className={
        className ??
        'cursor-pointer select-none px-3 py-2 text-left text-xs font-medium uppercase tracking-wide text-neutral-500 hover:bg-neutral-50'
      }
      onClick={handleClick}
    >
      <span className="inline-flex items-center gap-1">
        {label ?? field}
        <span aria-hidden className="text-neutral-400">
          {direction === 'ASC' ? '↑' : direction === 'DESC' ? '↓' : '↕'}
        </span>
      </span>
    </th>
  );
}
