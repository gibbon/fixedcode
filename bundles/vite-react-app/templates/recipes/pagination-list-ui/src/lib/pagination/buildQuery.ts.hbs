// Generated by fixedcode (recipe: pagination-list-ui).
//
// Serialise a `PageRequest` to the BFF query convention exactly:
//   ?page=0&size=20
//   ?sort=name,asc&sort=createdAt,desc        (multi-valued — repeat the param)
//   ?filter=status:eq:active&filter=name:like:foo
//
// All values are URL-encoded. The output never starts with `?` so callers can
// append it to any base URL via template literal.

import type { FilterSpec, PageRequest, SortSpec } from './types';

export function buildPageQuery(request: PageRequest): string {
  const params = new URLSearchParams();
  params.append('page', String(request.page));
  params.append('size', String(request.size));
  for (const s of request.sort) {
    params.append('sort', encodeSort(s));
  }
  for (const f of request.filters) {
    params.append('filter', encodeFilter(f));
  }
  return params.toString();
}

function encodeSort(s: SortSpec): string {
  return `${s.field},${s.direction.toLowerCase()}`;
}

function encodeFilter(f: FilterSpec): string {
  return `${f.field}:${f.op.toLowerCase()}:${f.value}`;
}
