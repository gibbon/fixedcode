// Generated by fixedcode (recipe: pagination-list-ui).
//
// Reusable hook for any list endpoint that follows the `pagination-filter-sort`
// BFF convention. State is local — no URL state, no router coupling.
// Re-fetches whenever any of `page`, `size`, `sort`, or `filters` changes.
//
// Usage:
//   const { data, isLoading, error, request, setPage, setSize, setSort, setFilters }
//     = usePagedList<Widget>('/widgets');
//
// To pre-seed sort or filters:
//   usePagedList<Widget>('/widgets', {
//     initialSort: [{ field: 'createdAt', direction: 'DESC' }],
//     initialFilters: [{ field: 'status', op: 'EQ', value: 'active' }],
//   });

import { useCallback, useEffect, useRef, useState } from 'react';
import { api } from '../api';
import { buildPageQuery } from './buildQuery';
import {
  emptyPageResponse,
  type FilterSpec,
  type PageRequest,
  type PageResponse,
  type SortSpec,
} from './types';

export interface UsePagedListOptions {
  /** Initial page index (zero-based). Default: 0. */
  initialPage?: number;
  /** Initial page size. Default: defaultPageSize from the recipe config. */
  initialSize?: number;
  initialSort?: SortSpec[];
  initialFilters?: FilterSpec[];
}

export interface UsePagedListResult<T> {
  /** Current page payload. Always defined — empty placeholder before the first fetch resolves. */
  data: PageResponse<T>;
  isLoading: boolean;
  error: Error | null;
  request: PageRequest;
  setPage: (page: number) => void;
  setSize: (size: number) => void;
  setSort: (sort: SortSpec[]) => void;
  setFilters: (filters: FilterSpec[]) => void;
  /** Append (or replace, if same field) a single filter clause. */
  addFilter: (filter: FilterSpec) => void;
  /** Drop every filter for the given field. */
  removeFilter: (field: string) => void;
  /** Manually re-fetch without changing the request (e.g. after a mutation elsewhere). */
  refresh: () => void;
}

const DEFAULT_PAGE_SIZE = {{paginationListUi.defaultPageSize}};

export function usePagedList<T>(
  endpoint: string,
  options: UsePagedListOptions = {},
): UsePagedListResult<T> {
  const initialRequest: PageRequest = {
    page: options.initialPage ?? 0,
    size: options.initialSize ?? DEFAULT_PAGE_SIZE,
    sort: options.initialSort ?? [],
    filters: options.initialFilters ?? [],
  };

  const [request, setRequest] = useState<PageRequest>(initialRequest);
  const [data, setData] = useState<PageResponse<T>>(() => emptyPageResponse<T>(initialRequest));
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<Error | null>(null);
  const [refreshKey, setRefreshKey] = useState(0);

  // Drop stale results if the request changes mid-flight.
  const requestIdRef = useRef(0);

  useEffect(() => {
    const requestId = ++requestIdRef.current;
    setIsLoading(true);
    setError(null);

    const url = `${endpoint}?${buildPageQuery(request)}`;
    api<PageResponse<T>>(url)
      .then((page) => {
        if (requestIdRef.current === requestId) {
          setData(page);
        }
      })
      .catch((err: unknown) => {
        if (requestIdRef.current === requestId) {
          setError(err instanceof Error ? err : new Error(String(err)));
        }
      })
      .finally(() => {
        if (requestIdRef.current === requestId) {
          setIsLoading(false);
        }
      });
  }, [endpoint, request, refreshKey]);

  const setPage = useCallback((page: number) => {
    setRequest((prev) => (prev.page === page ? prev : { ...prev, page }));
  }, []);

  const setSize = useCallback((size: number) => {
    setRequest((prev) => {
      if (prev.size === size) return prev;
      // Reset to first page — staying on `page=N` after enlarging the page
      // size usually shows the wrong slice.
      return { ...prev, size, page: 0 };
    });
  }, []);

  const setSort = useCallback((sort: SortSpec[]) => {
    setRequest((prev) => ({ ...prev, sort, page: 0 }));
  }, []);

  const setFilters = useCallback((filters: FilterSpec[]) => {
    setRequest((prev) => ({ ...prev, filters, page: 0 }));
  }, []);

  const addFilter = useCallback((filter: FilterSpec) => {
    setRequest((prev) => {
      const without = prev.filters.filter((f) => f.field !== filter.field);
      return { ...prev, filters: [...without, filter], page: 0 };
    });
  }, []);

  const removeFilter = useCallback((field: string) => {
    setRequest((prev) => {
      const next = prev.filters.filter((f) => f.field !== field);
      if (next.length === prev.filters.length) return prev;
      return { ...prev, filters: next, page: 0 };
    });
  }, []);

  const refresh = useCallback(() => {
    setRefreshKey((k) => k + 1);
  }, []);

  return {
    data,
    isLoading,
    error,
    request,
    setPage,
    setSize,
    setSort,
    setFilters,
    addFilter,
    removeFilter,
    refresh,
  };
}
