// Generated by fixedcode (recipe: form-validation).
//
// Resolves a react-hook-form `FieldError` by dotted path so that nested fields
// (e.g. `address.street`, `items.0.qty`) surface their inline error correctly.
//
// `errors[name]` only works for top-level fields; for `name = 'address.street'`
// the error lives at `errors.address.street`, not `errors['address.street']`.

import type { FieldError, FieldErrors } from 'react-hook-form';

export function getFieldError<TValues extends Record<string, unknown>>(
  errors: FieldErrors<TValues>,
  name: string,
): FieldError | undefined {
  let cursor: unknown = errors;
  for (const key of name.split('.')) {
    if (cursor && typeof cursor === 'object' && key in cursor) {
      cursor = (cursor as Record<string, unknown>)[key];
    } else {
      return undefined;
    }
  }
  // RHF leaf errors have at least `type` (and usually `message`). Anything else
  // is a parent node — treat it as "no error at this path."
  if (cursor && typeof cursor === 'object' && 'type' in cursor) {
    return cursor as FieldError;
  }
  return undefined;
}

/**
 * `address.street` → `address-street`. Dotted ids are valid HTML but pair
 * awkwardly with CSS selectors, so the field components emit a sanitised id.
 */
export function fieldId(name: string): string {
  return name.replace(/\./g, '-');
}
