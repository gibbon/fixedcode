// Generated by fixedcode (recipe: form-validation).
//
// Thin wrapper around react-hook-form's `useForm` that wires a Zod schema
// for validation and infers the form's TypeScript shape from the schema.
//
// Usage:
//   const schema = z.object({
//     email: z.string().email(),
//     age: z.number().min(18),
//   });
//   const form = useZodForm(schema);
//   <Form form={form} onSubmit={(values) => createUser(values)}>
//     <TextField form={form} name="email" label="Email" />
//     <NumberField form={form} name="age" label="Age" />
//     <button type="submit">Save</button>
//   </Form>

import { zodResolver } from '@hookform/resolvers/zod';
import { useForm, type DefaultValues, type UseFormProps, type UseFormReturn } from 'react-hook-form';
import type { ZodTypeAny, z } from 'zod';

export type ZodFormReturn<S extends ZodTypeAny> = UseFormReturn<z.infer<S>>;

export interface UseZodFormOptions<S extends ZodTypeAny>
  extends Omit<UseFormProps<z.infer<S>>, 'resolver' | 'defaultValues'> {
  defaultValues?: DefaultValues<z.infer<S>>;
}

export function useZodForm<S extends ZodTypeAny>(
  schema: S,
  options: UseZodFormOptions<S> = {},
): ZodFormReturn<S> {
  return useForm<z.infer<S>>({
    ...options,
    resolver: zodResolver(schema),
    // Validate on blur by default; aggressive `onChange` validation feels noisy
    // for typical admin forms. Override per-call via `options.mode` if needed.
    mode: options.mode ?? 'onBlur',
  });
}
