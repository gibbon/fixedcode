// Generated by fixedcode (recipe: form-validation) — extension point.
// Labelled <select> bound to a react-hook-form field name.

import type { SelectHTMLAttributes } from 'react';
import type { FieldPath, FieldValues, UseFormReturn } from 'react-hook-form';
import FieldError from './FieldError';

export interface SelectOption {
  value: string;
  label: string;
  disabled?: boolean;
}

export interface SelectProps<TValues extends FieldValues>
  extends Omit<SelectHTMLAttributes<HTMLSelectElement>, 'name' | 'form' | 'children'> {
  form: UseFormReturn<TValues>;
  name: FieldPath<TValues>;
  label: string;
  options: SelectOption[];
  /** Adds a leading option with empty value and the given label. */
  placeholder?: string;
  description?: string;
}

export default function Select<TValues extends FieldValues>({
  form,
  name,
  label,
  options,
  placeholder,
  description,
  className,
  ...selectProps
}: SelectProps<TValues>) {
  const error = form.formState.errors[name];
  const errorId = `${name}-error`;
  const descriptionId = description ? `${name}-description` : undefined;

  return (
    <div className={className ?? 'flex flex-col'}>
      <label htmlFor={name} className="text-sm font-medium text-neutral-700">
        {label}
      </label>
      {description ? (
        <p id={descriptionId} className="mt-0.5 text-xs text-neutral-500">
          {description}
        </p>
      ) : null}
      <select
        id={name}
        aria-invalid={error ? true : undefined}
        aria-describedby={
          [error ? errorId : null, descriptionId].filter(Boolean).join(' ') || undefined
        }
        className="mt-1 rounded border border-neutral-300 bg-white px-2 py-1.5 text-sm focus:border-neutral-500 focus:outline-none focus:ring-1 focus:ring-neutral-500 aria-[invalid=true]:border-red-400"
        {...selectProps}
        {...form.register(name)}
      >
        {placeholder ? (
          <option value="" disabled>
            {placeholder}
          </option>
        ) : null}
        {options.map((opt) => (
          <option key={opt.value} value={opt.value} disabled={opt.disabled}>
            {opt.label}
          </option>
        ))}
      </select>
      <FieldError error={error as never} id={errorId} />
    </div>
  );
}
