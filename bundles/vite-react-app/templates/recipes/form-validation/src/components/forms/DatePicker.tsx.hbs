// Generated by fixedcode (recipe: form-validation) — extension point.
// Labelled <input type="date"> bound to a react-hook-form field name.
// Stores the value as an ISO `YYYY-MM-DD` string (the native input's format) —
// validate with `z.string().date()` or coerce in the schema if you want a Date.

import type { InputHTMLAttributes } from 'react';
import type { FieldPath, FieldValues, UseFormReturn } from 'react-hook-form';
import { fieldId, getFieldError } from '../../lib/forms/getFieldError';
import FieldError from './FieldError';

export interface DatePickerProps<TValues extends FieldValues>
  extends Omit<InputHTMLAttributes<HTMLInputElement>, 'name' | 'form' | 'type'> {
  form: UseFormReturn<TValues>;
  name: FieldPath<TValues>;
  label: string;
  description?: string;
}

export default function DatePicker<TValues extends FieldValues>({
  form,
  name,
  label,
  description,
  className,
  ...inputProps
}: DatePickerProps<TValues>) {
  const error = getFieldError(form.formState.errors, name);
  const id = fieldId(name);
  const errorId = `${id}-error`;
  const descriptionId = description ? `${id}-description` : undefined;

  return (
    <div className={className ?? 'flex flex-col'}>
      <label htmlFor={id} className="text-sm font-medium text-neutral-700">
        {label}
      </label>
      {description ? (
        <p id={descriptionId} className="mt-0.5 text-xs text-neutral-500">
          {description}
        </p>
      ) : null}
      <input
        id={id}
        type="date"
        aria-invalid={error ? true : undefined}
        aria-describedby={
          [error ? errorId : null, descriptionId].filter(Boolean).join(' ') || undefined
        }
        className="mt-1 rounded border border-neutral-300 px-2 py-1.5 text-sm tabular-nums focus:border-neutral-500 focus:outline-none focus:ring-1 focus:ring-neutral-500 aria-[invalid=true]:border-red-400"
        {...inputProps}
        {...form.register(name)}
      />
      <FieldError error={error} id={errorId} />
    </div>
  );
}
