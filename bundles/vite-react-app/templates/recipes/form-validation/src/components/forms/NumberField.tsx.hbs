// Generated by fixedcode (recipe: form-validation) — extension point.
// Labelled <input type="number"> that registers with `valueAsNumber: true` so
// react-hook-form coerces empty strings to NaN and digits to numbers — Zod's
// `z.number()` then validates against the typed value.

import type { InputHTMLAttributes } from 'react';
import type { FieldPath, FieldValues, UseFormReturn } from 'react-hook-form';
import FieldError from './FieldError';

export interface NumberFieldProps<TValues extends FieldValues>
  extends Omit<InputHTMLAttributes<HTMLInputElement>, 'name' | 'form' | 'type'> {
  form: UseFormReturn<TValues>;
  name: FieldPath<TValues>;
  label: string;
  description?: string;
}

export default function NumberField<TValues extends FieldValues>({
  form,
  name,
  label,
  description,
  className,
  ...inputProps
}: NumberFieldProps<TValues>) {
  const error = form.formState.errors[name];
  const errorId = `${name}-error`;
  const descriptionId = description ? `${name}-description` : undefined;

  return (
    <div className={className ?? 'flex flex-col'}>
      <label htmlFor={name} className="text-sm font-medium text-neutral-700">
        {label}
      </label>
      {description ? (
        <p id={descriptionId} className="mt-0.5 text-xs text-neutral-500">
          {description}
        </p>
      ) : null}
      <input
        id={name}
        type="number"
        inputMode="decimal"
        aria-invalid={error ? true : undefined}
        aria-describedby={
          [error ? errorId : null, descriptionId].filter(Boolean).join(' ') || undefined
        }
        className="mt-1 rounded border border-neutral-300 px-2 py-1.5 text-sm tabular-nums focus:border-neutral-500 focus:outline-none focus:ring-1 focus:ring-neutral-500 aria-[invalid=true]:border-red-400"
        {...inputProps}
        {...form.register(name, { valueAsNumber: true })}
      />
      <FieldError error={error as never} id={errorId} />
    </div>
  );
}
