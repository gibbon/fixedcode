// Generated by fixedcode (recipe: form-validation) — extension point.
// Renders the validation error for a single field, or null if there's nothing
// to show. Used internally by TextField/NumberField/Select/DatePicker but also
// exported for custom inputs that want the same error styling.

import type { FieldError as RhfFieldError } from 'react-hook-form';

export interface FieldErrorProps {
  error: RhfFieldError | undefined;
  /** id used by `aria-describedby` so screen readers announce the error. */
  id?: string;
}

export default function FieldError({ error, id }: FieldErrorProps) {
  if (!error?.message) return null;
  return (
    <p id={id} className="mt-1 text-sm text-red-600">
      {error.message}
    </p>
  );
}
