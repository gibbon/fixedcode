// Generated by fixedcode (recipe: image-upload).
// Typed client for the BE image endpoints. No external deps — uses fetch + FormData.

import type { ImageDto, ImageVariant } from '../types/image';

const API_BASE = (import.meta.env.VITE_API_BASE_URL ?? '').replace(/\/+$/, '');
const API_PATH = '{{imageUpload.apiPath}}';

function endpoint(suffix = ''): string {
  return `${API_BASE}${API_PATH}${suffix}`;
}

export interface UploadOptions {
  /** Optional progress callback (0..1). Only fires when the browser supports XHR upload progress. */
  onProgress?: (fraction: number) => void;
  /** Optional AbortSignal to cancel the request. */
  signal?: AbortSignal;
}

/**
 * Upload a single image file. Returns the freshly created [ImageDto].
 * Uses XHR (not fetch) when `onProgress` is supplied so we can report upload progress.
 */
export async function uploadImage(file: File, opts: UploadOptions = {}): Promise<ImageDto> {
  const form = new FormData();
  form.append('file', file);

  if (opts.onProgress) {
    return await uploadViaXhr(form, opts);
  }

  const res = await fetch(endpoint(), {
    method: 'POST',
    body: form,
    signal: opts.signal,
  });
  if (!res.ok) {
    throw new Error(`uploadImage failed: ${res.status} ${res.statusText}`);
  }
  return (await res.json()) as ImageDto;
}

export async function deleteImage(id: string): Promise<void> {
  const res = await fetch(endpoint(`/${encodeURIComponent(id)}`), { method: 'DELETE' });
  if (!res.ok && res.status !== 404) {
    throw new Error(`deleteImage failed: ${res.status} ${res.statusText}`);
  }
}

export function getImageUrl(id: string, variant: ImageVariant = 'original'): string {
  const suffix = variant === 'thumbnail' ? '/binary?variant=thumbnail' : '/binary';
  return endpoint(`/${encodeURIComponent(id)}${suffix}`);
}

function uploadViaXhr(form: FormData, opts: UploadOptions): Promise<ImageDto> {
  return new Promise<ImageDto>((resolve, reject) => {
    const xhr = new XMLHttpRequest();
    xhr.open('POST', endpoint());
    xhr.responseType = 'json';

    if (opts.signal) {
      const onAbort = () => xhr.abort();
      if (opts.signal.aborted) {
        xhr.abort();
      } else {
        opts.signal.addEventListener('abort', onAbort, { once: true });
      }
    }

    if (xhr.upload && opts.onProgress) {
      xhr.upload.onprogress = (ev) => {
        if (ev.lengthComputable) {
          opts.onProgress?.(ev.loaded / ev.total);
        }
      };
    }

    xhr.onload = () => {
      if (xhr.status >= 200 && xhr.status < 300) {
        resolve(xhr.response as ImageDto);
      } else {
        reject(new Error(`uploadImage failed: ${xhr.status} ${xhr.statusText}`));
      }
    };
    xhr.onerror = () => reject(new Error('uploadImage failed: network error'));
    xhr.onabort = () => reject(new Error('uploadImage aborted'));

    xhr.send(form);
  });
}
