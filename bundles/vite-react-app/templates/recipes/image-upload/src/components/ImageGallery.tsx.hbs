// Generated by fixedcode (recipe: image-upload).
// Grid of thumbnails; click a tile for a full-size lightbox view.

import { useEffect, useRef, useState, type CSSProperties } from 'react';
import { deleteImage, getImageUrl } from '../lib/images';
import type { ImageDto } from '../types/image';

export interface ImageGalleryProps {
  images: ImageDto[];
  onDelete?: (id: string) => void;
}

const gridStyle: CSSProperties = {
  display: 'grid',
  gridTemplateColumns: 'repeat(auto-fill, minmax(160px, 1fr))',
  gap: 12,
};

const tileStyle: CSSProperties = {
  padding: 0,
  border: '1px solid #ddd',
  borderRadius: 6,
  overflow: 'hidden',
  cursor: 'pointer',
  background: '#fff',
  aspectRatio: '1 / 1',
};

const thumbImgStyle: CSSProperties = {
  width: '100%',
  height: '100%',
  objectFit: 'cover',
  display: 'block',
};

const dialogStyle: CSSProperties = {
  padding: 0,
  border: 'none',
  borderRadius: 8,
  maxWidth: '90vw',
  maxHeight: '90vh',
  background: 'transparent',
};

const lightboxStyle: CSSProperties = { background: '#000', position: 'relative' };

const fullImgStyle: CSSProperties = {
  display: 'block',
  maxWidth: '90vw',
  maxHeight: '80vh',
  margin: '0 auto',
};

const captionStyle: CSSProperties = {
  display: 'flex',
  justifyContent: 'space-between',
  padding: '8px 12px',
  background: '#111',
  color: '#eee',
  fontSize: 13,
};

const deleteButtonStyle: CSSProperties = {
  background: 'transparent',
  color: '#f88',
  border: '1px solid #844',
  borderRadius: 4,
  padding: '2px 8px',
  cursor: 'pointer',
};

const closeButtonStyle: CSSProperties = {
  background: 'transparent',
  color: '#eee',
  border: '1px solid #555',
  borderRadius: 4,
  padding: '2px 8px',
  cursor: 'pointer',
};

const captionActionsStyle: CSSProperties = { display: 'flex', gap: 12 };

export function ImageGallery({ images, onDelete }: ImageGalleryProps) {
  const [active, setActive] = useState<ImageDto | null>(null);
  const dialogRef = useRef<HTMLDialogElement>(null);

  useEffect(() => {
    const dlg = dialogRef.current;
    if (!dlg) return;
    if (active && !dlg.open) dlg.showModal();
    if (!active && dlg.open) dlg.close();
  }, [active]);

  const handleDelete = async (id: string) => {
    await deleteImage(id);
    setActive(null);
    onDelete?.(id);
  };

  return (
    <>
      <div style={gridStyle}>
        {images.map((img) => (
          <button
            key={img.id}
            type="button"
            onClick={() => setActive(img)}
            style={tileStyle}
            aria-label={`Open image ${img.id}`}
          >
            <img
              src={img.thumbnailUrl ?? getImageUrl(img.id, 'thumbnail')}
              alt=""
              loading="lazy"
              style={thumbImgStyle}
            />
          </button>
        ))}
      </div>

      <dialog ref={dialogRef} onClose={() => setActive(null)} style={dialogStyle}>
        {active && (
          <div style={lightboxStyle}>
            <img src={getImageUrl(active.id, 'original')} alt="" style={fullImgStyle} />
            <div style={captionStyle}>
              <span>
                {active.contentType} · {Math.round(active.sizeBytes / 1024)} KB
              </span>
              <span style={captionActionsStyle}>
                {onDelete && (
                  <button
                    type="button"
                    onClick={() => void handleDelete(active.id)}
                    style={deleteButtonStyle}
                  >
                    Delete
                  </button>
                )}
                <button type="button" onClick={() => setActive(null)} style={closeButtonStyle}>
                  Close
                </button>
              </span>
            </div>
          </div>
        )}
      </dialog>
    </>
  );
}

export default ImageGallery;
