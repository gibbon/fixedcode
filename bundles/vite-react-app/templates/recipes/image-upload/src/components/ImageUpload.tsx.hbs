// Generated by fixedcode (recipe: image-upload) — extension point.
// Drag-and-drop dropzone with progress indicator. Style/UX is yours to own.

import { useCallback, useMemo, useRef, useState, type CSSProperties } from 'react';
import { uploadImage } from '../lib/images';
import type { ImageDto } from '../types/image';

export interface ImageUploadProps {
  onUploaded?: (image: ImageDto) => void;
  /** Override the accepted MIME types (defaults to common image types). */
  accept?: string;
}

const trackStyle: CSSProperties = {
  marginTop: 12,
  height: 6,
  background: '#e6e6e6',
  borderRadius: 3,
  overflow: 'hidden',
};

const errorStyle: CSSProperties = {
  marginTop: 12,
  color: '#c33',
  fontSize: 14,
};

const hiddenInputStyle: CSSProperties = { display: 'none' };

export function ImageUpload({
  onUploaded,
  accept = 'image/jpeg,image/png,image/webp',
}: ImageUploadProps) {
  const inputRef = useRef<HTMLInputElement>(null);
  const [dragOver, setDragOver] = useState(false);
  const [progress, setProgress] = useState<number | null>(null);
  const [error, setError] = useState<string | null>(null);

  const upload = useCallback(
    async (file: File) => {
      setError(null);
      setProgress(0);
      try {
        const image = await uploadImage(file, { onProgress: (p) => setProgress(p) });
        setProgress(1);
        onUploaded?.(image);
      } catch (err) {
        setError(err instanceof Error ? err.message : 'upload failed');
      } finally {
        window.setTimeout(() => setProgress(null), 300);
      }
    },
    [onUploaded],
  );

  const onDrop = useCallback(
    (ev: React.DragEvent<HTMLDivElement>) => {
      ev.preventDefault();
      setDragOver(false);
      const file = ev.dataTransfer.files?.[0];
      if (file) void upload(file);
    },
    [upload],
  );

  const onPick = useCallback(
    (ev: React.ChangeEvent<HTMLInputElement>) => {
      const file = ev.target.files?.[0];
      if (file) void upload(file);
      ev.target.value = '';
    },
    [upload],
  );

  const dropzoneStyle: CSSProperties = useMemo(
    () => ({
      border: `2px dashed ${dragOver ? '#4a90e2' : '#bbb'}`,
      background: dragOver ? '#eaf4ff' : '#fafafa',
      borderRadius: 8,
      padding: 24,
      textAlign: 'center',
      cursor: 'pointer',
      transition: 'background 120ms, border-color 120ms',
    }),
    [dragOver],
  );

  const fillStyle: CSSProperties = useMemo(
    () => ({
      width: `${Math.round((progress ?? 0) * 100)}%`,
      height: '100%',
      background: '#4a90e2',
      transition: 'width 120ms linear',
    }),
    [progress],
  );

  return (
    <div
      onDragOver={(e) => {
        e.preventDefault();
        setDragOver(true);
      }}
      onDragLeave={() => setDragOver(false)}
      onDrop={onDrop}
      onClick={() => inputRef.current?.click()}
      role="button"
      tabIndex={0}
      style={dropzoneStyle}
    >
      <input
        ref={inputRef}
        type="file"
        accept={accept}
        onChange={onPick}
        style={hiddenInputStyle}
      />
      <p>
        {progress === null
          ? 'Drag an image here, or click to choose a file'
          : `Uploading… ${Math.round(progress * 100)}%`}
      </p>
      {progress !== null && (
        <div style={trackStyle}>
          <div style={fillStyle} />
        </div>
      )}
      {error && <p style={errorStyle}>{error}</p>}
    </div>
  );
}

export default ImageUpload;
