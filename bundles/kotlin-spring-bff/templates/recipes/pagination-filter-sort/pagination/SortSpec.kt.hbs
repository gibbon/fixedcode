package {{packageName}}.pagination

/**
 * Generated by fixedcode (recipe: pagination-filter-sort).
 *
 * Single sort key parsed from `?sort=field,direction`. Direction defaults to ASC
 * when the comma form is omitted (`?sort=field`).
 */
data class SortSpec(
    val field: String,
    val direction: Direction,
) {
    enum class Direction { ASC, DESC }

    companion object {
        /** Parse a single `?sort=` value. Returns null for blank/unparseable input. */
        fun parse(raw: String): SortSpec? {
            val trimmed = raw.trim()
            if (trimmed.isEmpty()) return null
            val parts = trimmed.split(',', limit = 2).map { it.trim() }
            val field = parts[0]
            if (field.isEmpty()) return null
            val direction = when (parts.getOrNull(1)?.lowercase()) {
                "desc" -> Direction.DESC
                "asc", null, "" -> Direction.ASC
                else -> Direction.ASC
            }
            return SortSpec(field, direction)
        }
    }
}
