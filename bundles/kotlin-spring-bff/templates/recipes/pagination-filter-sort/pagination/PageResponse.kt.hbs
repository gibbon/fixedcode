package {{packageName}}.pagination

/**
 * Generated by fixedcode (recipe: pagination-filter-sort).
 *
 * Standard wire-format envelope for paginated list endpoints.
 * The `vite-react-app` `pagination-list-ui` recipe expects this exact shape.
 *
 * Fields chosen to cover what a typical FE table needs without recomputing offsets:
 * - `content` — current page's items
 * - `page`, `size` — echo of the (possibly capped) request
 * - `totalElements`, `totalPages` — aggregate counts
 * - `numberOfElements` — `content.size`, useful for "showing X of Y" labels
 * - `first`, `last` — convenience aliases (`!hasPrevious`, `!hasNext`)
 * - `hasNext`, `hasPrevious` — pagination control hints
 */
data class PageResponse<T>(
    val content: List<T>,
    val page: Int,
    val size: Int,
    val totalElements: Long,
    val totalPages: Int,
    val numberOfElements: Int,
    val first: Boolean,
    val last: Boolean,
    val hasNext: Boolean,
    val hasPrevious: Boolean,
) {
    companion object {
        /**
         * Build a response from a content slice + the originating [PageRequest] + total count.
         * Assumes `request.size >= 1` (the [PageRequestArgumentResolver] enforces this).
         */
        fun <T> of(content: List<T>, request: PageRequest, totalElements: Long): PageResponse<T> {
            val totalPages = ((totalElements + request.size - 1) / request.size).toInt()
            val hasPrevious = request.page > 0
            val hasNext = request.page + 1 < totalPages
            return PageResponse(
                content = content,
                page = request.page,
                size = request.size,
                totalElements = totalElements,
                totalPages = totalPages,
                numberOfElements = content.size,
                first = !hasPrevious,
                last = !hasNext,
                hasNext = hasNext,
                hasPrevious = hasPrevious,
            )
        }

        /** Map the content list of an existing response without re-running pagination math. */
        fun <T, R> map(source: PageResponse<T>, transform: (T) -> R): PageResponse<R> {
            val mapped = source.content.map(transform)
            return PageResponse(
                content = mapped,
                page = source.page,
                size = source.size,
                totalElements = source.totalElements,
                totalPages = source.totalPages,
                numberOfElements = mapped.size,
                first = source.first,
                last = source.last,
                hasNext = source.hasNext,
                hasPrevious = source.hasPrevious,
            )
        }
    }
}
