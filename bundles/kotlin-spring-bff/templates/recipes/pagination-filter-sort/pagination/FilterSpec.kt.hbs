package {{packageName}}.pagination

/**
 * Generated by fixedcode (recipe: pagination-filter-sort).
 *
 * Single filter clause parsed from `?filter=field:op:value`. The op is optional —
 * `?filter=name:foo` is interpreted as `name:eq:foo`.
 *
 * For `in` lists, separate values with `|` — e.g. `?filter=status:in:active|trial`.
 */
data class FilterSpec(
    val field: String,
    val op: Op,
    val value: String,
) {
    enum class Op {
        EQ, NE, GT, GTE, LT, LTE, LIKE, IN;

        companion object {
            fun fromTokenOrNull(token: String): Op? = when (token.lowercase()) {
                "eq" -> EQ
                "ne" -> NE
                "gt" -> GT
                "gte" -> GTE
                "lt" -> LT
                "lte" -> LTE
                "like" -> LIKE
                "in" -> IN
                else -> null
            }
        }
    }

    /** For `IN` ops, split the value on `|` (the parser's chosen separator). */
    fun valuesIn(): List<String> = value.split('|').map { it.trim() }.filter { it.isNotEmpty() }

    companion object {
        /** Parse a single `?filter=` value. Returns null for blank/unparseable input. */
        fun parse(raw: String): FilterSpec? {
            val trimmed = raw.trim()
            if (trimmed.isEmpty()) return null
            // Split into at most three parts: field, op, value. Value may contain colons.
            val firstColon = trimmed.indexOf(':')
            if (firstColon <= 0) return null
            val field = trimmed.substring(0, firstColon).trim()
            if (field.isEmpty()) return null
            val rest = trimmed.substring(firstColon + 1)
            val secondColon = rest.indexOf(':')
            return if (secondColon < 0) {
                // No op token — treat the whole rest as the value, op defaults to EQ.
                FilterSpec(field, Op.EQ, rest)
            } else {
                val opToken = rest.substring(0, secondColon).trim()
                val value = rest.substring(secondColon + 1)
                val op = Op.fromTokenOrNull(opToken)
                if (op == null) {
                    // Unknown token — treat the whole rest as a value with EQ.
                    FilterSpec(field, Op.EQ, rest)
                } else {
                    FilterSpec(field, op, value)
                }
            }
        }
    }
}
