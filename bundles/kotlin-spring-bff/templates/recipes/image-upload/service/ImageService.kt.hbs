package {{packageName}}.service

import {{packageName}}.dto.ImageDto
import java.io.InputStream
import java.util.UUID

/**
 * Generated by fixedcode (recipe: image-upload).
 *
 * Storage-agnostic interface for image upload, retrieval, and deletion.
 * The default implementation [LocalImageService] writes to local disk; swap it
 * out (S3, GCS, Azure Blob, etc.) without touching this contract.
 */
interface ImageService {

    /** Persist an image and return its metadata. */
    fun upload(bytes: ByteArray, originalFilename: String, contentType: String): ImageDto

    /** Fetch metadata for an image by id. Throws [{{packageName}}.exception.ImageNotFoundException] if missing. */
    fun get(id: UUID): ImageDto

    /** Open a binary stream of the image (variant = "original" or "thumbnail"). */
    fun openStream(id: UUID, variant: String): ImageStreamPayload

    /** Remove an image (and any thumbnail) from storage. */
    fun delete(id: UUID)
}

/** Payload returned by [ImageService.openStream]. Caller is responsible for closing the stream. */
data class ImageStreamPayload(
    val stream: InputStream,
    val contentType: String,
    val sizeBytes: Long,
)
