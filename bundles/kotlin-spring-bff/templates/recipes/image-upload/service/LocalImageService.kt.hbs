package {{packageName}}.service

import {{packageName}}.dto.ImageDto
import {{packageName}}.exception.ImageNotFoundException
import {{packageName}}.exception.ImageProcessingException
import org.springframework.beans.factory.annotation.Value
import org.springframework.stereotype.Service
import java.awt.Graphics2D
import java.awt.RenderingHints
import java.awt.image.BufferedImage
import java.io.ByteArrayInputStream
import java.io.ByteArrayOutputStream
import java.nio.file.Files
import java.nio.file.Path
import java.nio.file.StandardCopyOption
import java.time.Instant
import java.util.UUID
import java.util.concurrent.ConcurrentHashMap
import javax.imageio.ImageIO

/**
 * Generated by fixedcode (recipe: image-upload) — extension point.
 *
 * Default implementation: writes images to the local filesystem under
 * `app.images.dir`. Computes a 256-px-wide thumbnail via java.awt.
 *
 * Swap this out (S3, GCS, Azure Blob, etc.) without changing the
 * [ImageService] interface or the controller.
 *
 * Metadata is held in-memory (a ConcurrentHashMap). For production, persist it
 * to your database.
 */
@Service
class LocalImageService(
    @Value("\${app.images.dir}") private val rootDirRaw: String,
    @Value("\${app.images.maxSizeBytes:10485760}") private val maxSizeBytes: Long,
    @Value("\${app.images.allowedMimeTypes:image/jpeg,image/png,image/webp}") private val allowedMimeTypesRaw: String,
) : ImageService {

    private val rootDir: Path = Path.of(rootDirRaw)
    private val originalsDir: Path = rootDir.resolve("originals")
    private val thumbnailsDir: Path = rootDir.resolve("thumbnails")
    private val allowedMimeTypes: Set<String> =
        allowedMimeTypesRaw.split(',').map { it.trim().lowercase() }.filter { it.isNotEmpty() }.toSet()

    private val metadata = ConcurrentHashMap<UUID, ImageDto>()
    private val contentTypeById = ConcurrentHashMap<UUID, String>()
    private val thumbContentTypeById = ConcurrentHashMap<UUID, String>()

    init {
        Files.createDirectories(originalsDir)
        Files.createDirectories(thumbnailsDir)
    }

    override fun upload(bytes: ByteArray, originalFilename: String, contentType: String): ImageDto {
        if (bytes.size.toLong() > maxSizeBytes) {
            throw ImageProcessingException("file exceeds maxSizeBytes ($maxSizeBytes)")
        }
        val ct = contentType.lowercase()
        if (allowedMimeTypes.isNotEmpty() && ct !in allowedMimeTypes) {
            throw ImageProcessingException("unsupported content type: $contentType")
        }

        val id = UUID.randomUUID()
        val ext = extensionFor(ct, originalFilename)
        val originalPath = originalsDir.resolve("$id.$ext")
        Files.write(originalPath, bytes)

        val thumbnailUrl: String? = try {
            writeThumbnail(id, bytes, ct)
            "/images/$id/binary?variant=thumbnail"
        } catch (e: Exception) {
            // Thumbnailing is best-effort; original is already saved.
            null
        }

        val dto = ImageDto(
            id = id,
            contentType = contentType,
            sizeBytes = bytes.size.toLong(),
            url = "/images/$id/binary",
            thumbnailUrl = thumbnailUrl,
            createdAt = Instant.now(),
        )
        metadata[id] = dto
        contentTypeById[id] = contentType
        return dto
    }

    override fun get(id: UUID): ImageDto = metadata[id] ?: throw ImageNotFoundException(id)

    override fun openStream(id: UUID, variant: String): ImageStreamPayload {
        val dto = metadata[id] ?: throw ImageNotFoundException(id)
        return when (variant) {
            "thumbnail" -> {
                val ct = thumbContentTypeById[id] ?: "image/png"
                val path = findFile(thumbnailsDir, id) ?: throw ImageNotFoundException(id)
                ImageStreamPayload(Files.newInputStream(path), ct, Files.size(path))
            }
            else -> {
                val ct = contentTypeById[id] ?: dto.contentType
                val path = findFile(originalsDir, id) ?: throw ImageNotFoundException(id)
                ImageStreamPayload(Files.newInputStream(path), ct, Files.size(path))
            }
        }
    }

    override fun delete(id: UUID) {
        metadata.remove(id) ?: throw ImageNotFoundException(id)
        contentTypeById.remove(id)
        thumbContentTypeById.remove(id)
        findFile(originalsDir, id)?.let { Files.deleteIfExists(it) }
        findFile(thumbnailsDir, id)?.let { Files.deleteIfExists(it) }
    }

    // --- helpers -------------------------------------------------------------

    private fun writeThumbnail(id: UUID, bytes: ByteArray, contentType: String) {
        val source = ImageIO.read(ByteArrayInputStream(bytes))
            ?: throw ImageProcessingException("could not decode image bytes")
        val targetWidth = 256
        if (source.width <= targetWidth) {
            // No need to scale; just rewrite as PNG to keep variant uniform.
            val out = ByteArrayOutputStream()
            ImageIO.write(source, "png", out)
            Files.write(thumbnailsDir.resolve("$id.png"), out.toByteArray(), StandardCopyOption.REPLACE_EXISTING)
            thumbContentTypeById[id] = "image/png"
            return
        }
        val ratio = targetWidth.toDouble() / source.width.toDouble()
        val targetHeight = (source.height * ratio).toInt().coerceAtLeast(1)
        val thumb = BufferedImage(targetWidth, targetHeight, BufferedImage.TYPE_INT_ARGB)
        val g: Graphics2D = thumb.createGraphics()
        try {
            g.setRenderingHint(RenderingHints.KEY_INTERPOLATION, RenderingHints.VALUE_INTERPOLATION_BILINEAR)
            g.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY)
            g.drawImage(source, 0, 0, targetWidth, targetHeight, null)
        } finally {
            g.dispose()
        }
        val out = ByteArrayOutputStream()
        val format = if (contentType.endsWith("jpeg") || contentType.endsWith("jpg")) "jpg" else "png"
        ImageIO.write(thumb, format, out)
        Files.write(thumbnailsDir.resolve("$id.$format"), out.toByteArray(), StandardCopyOption.REPLACE_EXISTING)
        thumbContentTypeById[id] = if (format == "jpg") "image/jpeg" else "image/png"
    }

    private fun findFile(dir: Path, id: UUID): Path? {
        if (!Files.isDirectory(dir)) return null
        Files.newDirectoryStream(dir, "$id.*").use { stream ->
            for (p in stream) return p
        }
        return null
    }

    private fun extensionFor(contentType: String, originalFilename: String): String {
        return when {
            contentType.endsWith("jpeg") || contentType.endsWith("jpg") -> "jpg"
            contentType.endsWith("png") -> "png"
            contentType.endsWith("webp") -> "webp"
            else -> originalFilename.substringAfterLast('.', "bin").lowercase()
        }
    }
}
