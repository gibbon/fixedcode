# Generated by fixedcode (recipe: image-upload).
# Active automatically — Spring loads `application-image-upload.yml` whenever
# the `image-upload` profile (or no specific profile) is selected.
app:
  images:
    dir: {{springProp "APP_IMAGES_DIR" (concat "/var/lib/" appName.kebab "/images")}}
    maxSizeBytes: {{springProp "APP_IMAGES_MAX_SIZE_BYTES" "10485760"}}
    allowedMimeTypes: image/jpeg,image/png,image/webp

spring:
  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 10MB
