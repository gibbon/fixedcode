/**
 * Generated by fixedcode (recipe: audit-log).
 *
 * Append-only ledger row written by [AuditLogEventListener] for every
 * [AuditEvent] published via [AuditLogPublisher]. The table is intentionally
 * narrow — production systems often layer richer analytical schemas on top
 * (or stream to Kafka) but the canonical record stays here.
 */
@Entity
@Table(name = "audit_log")
data class AuditLog(
    @Id
    val id: UUID = UUID.randomUUID(),

    @Column(name = "aggregate_type", nullable = false)
