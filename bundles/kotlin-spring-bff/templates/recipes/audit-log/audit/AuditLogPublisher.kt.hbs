package {{packageName}}.audit

import org.springframework.context.ApplicationEventPublisher
import org.springframework.stereotype.Component
import java.util.UUID

/**
 * Generated by fixedcode (recipe: audit-log).
 *
 * Convenience facade your domain code calls to record an audit entry.
 * Publishes a Spring [AuditEvent] which [AuditLogEventListener] persists
 * (and forwards to [AuditLogOutboundAdapter] for downstream pipes).
 *
 * Usage:
 *   class WidgetService(val audit: AuditLogPublisher) {
 *       fun create(spec: WidgetSpec): Widget {
 *           val w = repo.save(Widget.from(spec))
 *           audit.created(aggregateType = "Widget", aggregateId = w.id.toString(), payload = w)
 *           return w
 *       }
 *   }
 */
@Component
class AuditLogPublisher(
    private val publisher: ApplicationEventPublisher,
) {
    fun created(
        aggregateType: String,
        aggregateId: String,
        payload: Any? = null,
        actor: String? = null,
        correlationId: UUID? = null,
    ) = publish(aggregateType, aggregateId, AuditAction.CREATED, payload, actor, correlationId)

    fun updated(
        aggregateType: String,
        aggregateId: String,
        payload: Any? = null,
        actor: String? = null,
        correlationId: UUID? = null,
    ) = publish(aggregateType, aggregateId, AuditAction.UPDATED, payload, actor, correlationId)

    fun deleted(
        aggregateType: String,
        aggregateId: String,
        payload: Any? = null,
        actor: String? = null,
        correlationId: UUID? = null,
    ) = publish(aggregateType, aggregateId, AuditAction.DELETED, payload, actor, correlationId)

    private fun publish(
        aggregateType: String,
        aggregateId: String,
        action: AuditAction,
        payload: Any?,
        actor: String?,
        correlationId: UUID?,
    ) {
        publisher.publishEvent(
            AuditEvent(
                aggregateType = aggregateType,
                aggregateId = aggregateId,
                action = action,
                actor = actor,
                payload = payload,
                correlationId = correlationId,
            ),
        )
    }
}
