package {{packageName}}.audit

import com.fasterxml.jackson.databind.ObjectMapper
{{#if auditLog.hasActorHeader}}
import jakarta.servlet.http.HttpServletRequest
{{/if}}
import mu.KotlinLogging
import org.springframework.context.event.EventListener
import org.springframework.security.core.context.SecurityContextHolder
import org.springframework.stereotype.Component
import java.util.UUID

private val log = KotlinLogging.logger {}

/**
 * Generated by fixedcode (recipe: audit-log).
 *
 * Persists every [AuditEvent] published via the [AuditLogPublisher], then
 * hands the row to [AuditLogOutboundAdapter] for downstream propagation.
 *
 * Actor resolution order:
 *   1. Explicit `event.actor` (highest priority — the publisher caller knows best)
 *   2. Spring Security principal name when an authenticated user is in scope
 *   3. {{#if auditLog.hasActorHeader}}`{{auditLog.actorHeader}}` request header (service-to-service calls){{else}}(skipped — no actor header configured){{/if}}
 *   4. `null` (recorded as an unknown / system actor)
 */
@Component
class AuditLogEventListener(
    private val repository: AuditLogRepository,
    private val outbound: AuditLogOutboundAdapter,
    private val objectMapper: ObjectMapper,
{{#if auditLog.hasActorHeader}}
    private val request: HttpServletRequest,
{{/if}}
) {

    @EventListener
    fun on(event: AuditEvent) {
        val payloadJson = serialize(event.payload)
        val actor = resolveActor(event.actor)
        val entry = AuditLog(
            id = UUID.randomUUID(),
            aggregateType = event.aggregateType,
            aggregateId = event.aggregateId,
            action = event.action,
            actor = actor,
            payload = payloadJson,
            correlationId = event.correlationId,
            occurredAt = event.occurredAt,
        )
        val saved = repository.save(entry)
        try {
            outbound.forward(saved)
        } catch (ex: Exception) {
            // Outbound is best-effort. The DB row is already committed; surface
            // the failure so on-call can repair the downstream sink, but never
            // fail the originating request.
            log.warn(ex) { "audit-log outbound forward failed for ${saved.id}" }
        }
    }

    private fun serialize(payload: Any?): String? {
        if (payload == null) return null
        return try {
            objectMapper.writeValueAsString(payload)
        } catch (ex: Exception) {
            log.warn(ex) { "audit-log payload serialization failed; recording null payload" }
            null
        }
    }

    private fun resolveActor(explicit: String?): String? {
        if (!explicit.isNullOrBlank()) return explicit
        val securityActor = SecurityContextHolder.getContext().authentication
            ?.takeIf { it.isAuthenticated && it.name != "anonymousUser" }
            ?.name
        if (!securityActor.isNullOrBlank()) return securityActor
{{#if auditLog.hasActorHeader}}
        val headerActor = try {
            request.getHeader("{{auditLog.actorHeader}}")
        } catch (_: Exception) {
            null  // No request scope (e.g. event published from a @Scheduled job).
        }
        if (!headerActor.isNullOrBlank()) return headerActor
{{/if}}
        return null
    }
}
