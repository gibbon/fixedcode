/**
 * Generated by fixedcode (recipe: audit-log) — extension point.
 *
 * Read-only listing of audit-log rows. Filterable by aggregate type, aggregate
 * id, or actor. The `SecurityConfig` (when users-management is also enabled)
 * locks `/api/audit-log/**` to ROLE_ADMIN by default — restrict further as
 * your domain needs (e.g. tenant scoping).
 *
 * The endpoint returns a flat `List<AuditLogDto>` on purpose — pair it with
 * the `pagination-filter-sort` recipe if you want the full
 * `?page&size&sort&filter` convention; otherwise the simple paging here is
 * usually enough for an internal admin UI.
 */
@RestController
@RequestMapping("/api/audit-log")
class AuditLogController(
    private val repository: AuditLogRepository,
) {

    @GetMapping
    fun list(
        @RequestParam(required = false) aggregateType: String?,
        @RequestParam(required = false) aggregateId: String?,
        @RequestParam(required = false) actor: String?,
        @RequestParam(defaultValue = "0") page: Int,
        @RequestParam(defaultValue = "50") size: Int,
    ): List<AuditLogDto> {
        val cappedSize = size.coerceIn(1, 200)
        val pageable = PageRequest.of(
            page.coerceAtLeast(0),
            cappedSize,
            Sort.by(Sort.Direction.DESC, "occurredAt"),
        )
        val result = when {
            aggregateType != null && aggregateId != null ->
                repository.findByAggregateTypeAndAggregateIdOrderByOccurredAtDesc(
                    aggregateType, aggregateId, pageable,
                )
            aggregateType != null ->
                repository.findByAggregateTypeOrderByOccurredAtDesc(aggregateType, pageable)
            actor != null ->
                repository.findByActorOrderByOccurredAtDesc(actor, pageable)
            else -> repository.findAll(pageable)
        }
        return result.content.map(AuditLogDto::from)
    }
}
