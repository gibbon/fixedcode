-- Generated by fixedcode (recipe: audit-log).
-- Versioned at V100 to sit comfortably above any aggregate migrations the
-- spring-domain bundle generates (which usually occupy V001..V099).

CREATE TABLE audit_log (
    id              UUID         PRIMARY KEY,
    aggregate_type  VARCHAR(255) NOT NULL,
    aggregate_id    VARCHAR(255) NOT NULL,
    action          VARCHAR(16)  NOT NULL,
    actor           VARCHAR(255),
    payload         JSONB,
    correlation_id  UUID,
    occurred_at     TIMESTAMPTZ  NOT NULL
);

CREATE INDEX idx_audit_log_aggregate
    ON audit_log (aggregate_type, aggregate_id, occurred_at DESC);

CREATE INDEX idx_audit_log_actor
    ON audit_log (actor, occurred_at DESC);

CREATE INDEX idx_audit_log_occurred_at
    ON audit_log (occurred_at DESC);

CREATE INDEX idx_audit_log_correlation
    ON audit_log (correlation_id)
    WHERE correlation_id IS NOT NULL;
