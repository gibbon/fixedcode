package {{packageName}}.auth

import io.jsonwebtoken.Claims
import io.jsonwebtoken.Jwts
import io.jsonwebtoken.security.Keys
import org.springframework.beans.factory.annotation.Value
import org.springframework.stereotype.Component
import java.time.Duration
import java.time.Instant
import java.util.Date
import javax.crypto.SecretKey

/**
 * Generated by fixedcode (recipe: users-management) — extension point.
 *
 * Default impl: HS256 JWTs signed with `app.auth.jwtSecret`. Tokens carry
 * `sub` (user id), `email`, and `role` claims.
 *
 * To swap to Clerk / Auth0 / Supabase: re-implement `issue()` and `verify()`
 * (or replace the Bean entirely). The rest of the recipe only depends on the
 * `JwtPrincipal` shape returned by `verify()`.
 */
@Component
class JwtService(
    @Value("{{springProp "app.auth.jwtSecret" "change-me-in-prod-min-32-chars-please"}}") jwtSecret: String,
    @Value("{{springProp "app.auth.tokenTtlMinutes" "1440"}}") private val tokenTtlMinutes: Long,
) {
    private val key: SecretKey = Keys.hmacShaKeyFor(padTo32Bytes(jwtSecret).toByteArray(Charsets.UTF_8))
    private val ttl: Duration = Duration.ofMinutes(tokenTtlMinutes)

    fun issue(userId: String, email: String, role: String): String {
        val now = Instant.now()
        return Jwts.builder()
            .subject(userId)
            .claim("email", email)
            .claim("role", role)
            .issuedAt(Date.from(now))
            .expiration(Date.from(now.plus(ttl)))
            .signWith(key, Jwts.SIG.HS256)
            .compact()
    }

    fun verify(token: String): JwtPrincipal {
        val claims: Claims = Jwts.parser()
            .verifyWith(key)
            .build()
            .parseSignedClaims(token)
            .payload
        return JwtPrincipal(
            userId = claims.subject,
            email = claims["email"] as? String ?: "",
            role = claims["role"] as? String ?: "USER",
        )
    }

    private fun padTo32Bytes(s: String): String {
        // HS256 keys must be ≥ 256 bits. Pad short dev secrets so the app starts.
        if (s.toByteArray(Charsets.UTF_8).size >= 32) return s
        return s.padEnd(32, '*')
    }
}

data class JwtPrincipal(
    val userId: String,
    val email: String,
    val role: String,
)
