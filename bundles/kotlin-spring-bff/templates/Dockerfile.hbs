# Generated by fixedcode (bundle: kotlin-spring-bff)
# Build the jar locally with `./gradlew bootJar` before `docker build`.
FROM eclipse-temurin:{{javaVersion}}-jre-alpine
WORKDIR /app

RUN apk add --no-cache curl

COPY build/libs/*-SNAPSHOT.jar app.jar

RUN addgroup -g 1001 -S appuser && adduser -u 1001 -S appuser -G appuser \
    && chown appuser:appuser app.jar
USER appuser

ENV JAVA_TOOL_OPTIONS="-Xmx512m -Xms256m"

EXPOSE {{port}}

HEALTHCHECK --interval=30s --timeout=3s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:{{port}}/actuator/health || exit 1

ENTRYPOINT ["java", "-jar", "/app/app.jar"]
