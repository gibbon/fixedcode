    /**
     * Handle Spring framework exceptions that indicate client errors (400).
     * Catches common Spring MVC/Web exceptions before GlobalExceptionHandler's RuntimeException catch-all.
     */
    @ExceptionHandler(
        org.springframework.web.bind.MissingServletRequestParameterException::class,
        org.springframework.web.method.annotation.MethodArgumentTypeMismatchException::class,
        org.springframework.web.servlet.resource.NoResourceFoundException::class
    )
    fun handleSpringClientError(ex: Exception): ResponseEntity<Map<String, Any>> {
        val errorCode = when (ex) {
            is org.springframework.web.servlet.resource.NoResourceFoundException -> NOT_FOUND_ERROR_CODE
            else -> VALIDATION_ERROR_CODE
        }
        
        val httpStatus = when (ex) {
            is org.springframework.web.servlet.resource.NoResourceFoundException -> HttpStatus.NOT_FOUND
            else -> HttpStatus.BAD_REQUEST
        }
        
        val message = ex.message ?: "Invalid request"
        
        logger.debug("Spring framework client error", logData(messageDetails = mapOf(
            "errorCode" to errorCode,
            "exceptionType" to ex.javaClass.simpleName,
            "message" to message
        )))
        
        val error = mapOf(
            "code" to errorCode,
            "message" to message,
            "field" to null
        )
        
        return ResponseEntity
            .status(httpStatus)
            .body(mapOf("errors" to listOf(error)))
    }

    /**
     * Catch-all handler for unexpected exceptions.
     * Logs full stack trace but returns generic error to client.
     * This should rarely be reached as specific handlers above catch most cases.
     */
    @ExceptionHandler(Exception::class)
    fun handleGenericException(ex: Exception): ResponseEntity<Map<String, Any>> {
        val errorCode = "GA.{{ title .DomainPackage }}.500000"
        
        // Log full exception with stack trace for debugging
        logger.error("Unexpected error occurred", ex, logData(messageDetails = mapOf(
            "errorCode" to errorCode,
            "exceptionType" to ex.javaClass.simpleName,
            "message" to ex.message
        )))
        
        // Return generic error to client (don't expose internal details)
        val error = mapOf(
            "code" to errorCode,
            "message" to "An unexpected error occurred. Please contact support with the correlation ID from the response headers.",
            "field" to null
        )
        
        return ResponseEntity
            .status(HttpStatus.INTERNAL_SERVER_ERROR)
            .body(mapOf("errors" to listOf(error)))
    }
