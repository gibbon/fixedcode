        return when (cause) {
            is DuplicateKeyException -> handleDuplicateKey(cause)
            is org.springframework.dao.OptimisticLockingFailureException -> handleOptimisticLockingFailure(cause)
            is DataIntegrityViolationException -> handleDataIntegrityViolation(cause)
            else -> throw ex
        }
    }

    @ExceptionHandler(DuplicateKeyException::class)
    fun handleDuplicateKey(ex: DuplicateKeyException): ResponseEntity<Map<String, Any>> {
        val message = ex.message ?: ""
        
        // Extract constraint name from exception message
        val constraintPattern = Regex("""constraint\s+"([^"]+)"""", RegexOption.IGNORE_CASE)
        val indexPattern = Regex("""index\s+"([^"]+)"""", RegexOption.IGNORE_CASE)
        
        val constraintName = constraintPattern.find(message)?.groupValues?.get(1)
            ?: indexPattern.find(message)?.groupValues?.get(1)
        
        val errorCode = CONFLICT_ERROR_CODE
        logger.warn("Duplicate key violation", logData(messageDetails = mapOf(
            "errorCode" to errorCode,
            "constraint" to constraintName,
            "message" to message
        )))

        val error = mapOf(
            "code" to errorCode,
            "message" to "A unique constraint was violated. This record already exists.",
            "field" to constraintName
        )

        return ResponseEntity
            .status(HttpStatus.CONFLICT)
            .body(mapOf("errors" to listOf(error)))
    }

    @ExceptionHandler(DataIntegrityViolationException::class)
    fun handleDataIntegrityViolation(ex: DataIntegrityViolationException): ResponseEntity<Map<String, Any>> {
        val message = ex.message ?: ""

        // Extract constraint name from exception message
        val constraintPattern = Regex("""constraint\s+"([^"]+)"""", RegexOption.IGNORE_CASE)
        val indexPattern = Regex("""index\s+"([^"]+)"""", RegexOption.IGNORE_CASE)

        val constraintName = constraintPattern.find(message)?.groupValues?.get(1)
            ?: indexPattern.find(message)?.groupValues?.get(1)
            ?: ""

        // Extract field name from constraint (e.g., "idx_table_field_unique" -> "field")
        val fieldPattern = Regex("""idx_\w+_(.+)_unique""", RegexOption.IGNORE_CASE)
        val fieldName = fieldPattern.find(constraintName)?.groupValues?.get(1)?.replace("_", " ") ?: "field"

        val friendlyMessage = when {
            constraintName.contains("unique") -> "This $fieldName already exists and must be unique"
            message.lowercase().contains("unique") -> "A unique constraint was violated"
            else -> "A data constraint was violated. Please check your input values."
        }

        val errorCode = CONFLICT_ERROR_CODE
        logger.warn("Data integrity violation", logData(messageDetails = mapOf(
            "errorCode" to errorCode,
            "constraint" to constraintName,
            "field" to fieldName
        )))

        val error = mapOf(
            "code" to errorCode,
            "message" to friendlyMessage,
            "field" to fieldName.takeIf { it != "field" }
        )

        return ResponseEntity
            .status(HttpStatus.CONFLICT)
            .body(mapOf("errors" to listOf(error)))
    }

