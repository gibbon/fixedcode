    @ExceptionHandler(HttpMessageNotReadableException::class)
    fun handleHttpMessageNotReadable(ex: HttpMessageNotReadableException): ResponseEntity<Map<String, Any>> {
        val cause = ex.cause

        return when (cause) {
            is MismatchedInputException -> {
                val fieldName = cause.path.joinToString(".") { it.fieldName ?: "[${it.index}]" }
                val errorCode = TYPE_MISMATCH_ERROR_CODE

                // Check if this is a missing required field
                val message = if (cause.message?.contains("missing") == true ||
                    cause.message?.contains("required") == true ||
                    cause.message?.contains("Cannot construct instance") == true
                ) {
                    "This field is required"
                } else {
                    val expectedType = when {
                        cause.targetType?.isArray == true -> "array"
                        cause.targetType?.name?.contains("List") == true -> "array"
                        else -> cause.targetType?.simpleName?.lowercase() ?: "unknown"
                    }
                    "Invalid type for field '$fieldName'. Expected $expectedType but received different type."
                }

                logger.debug("HTTP message not readable", logData(messageDetails = mapOf(
                    "errorCode" to errorCode,
                    "field" to fieldName,
                    "message" to message
                )))

                ResponseEntity
                    .badRequest()
                    .body(
                        mapOf(
                            "errors" to listOf(
                                mapOf(
                                    "field" to fieldName,
                                    "message" to message,
                                    "code" to errorCode
                                )
                            )
                        )
                    )
            }

            else -> {
                val errorCode = INVALID_FORMAT_ERROR_CODE
                logger.debug("Invalid request format", logData(messageDetails = mapOf(
                    "errorCode" to errorCode
                )))
                ResponseEntity
                    .badRequest()
                    .body(
