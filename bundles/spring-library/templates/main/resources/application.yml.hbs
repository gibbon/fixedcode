spring:
  profiles:
    # Default to libdev profile for development
    # Override with --spring.profiles.active=<profile> for other environments
    active: libdev
  application:
    name: {{LibraryName}}

  # Kafka producer configuration for outbox publisher
  kafka:
    bootstrap-servers: ${KAFKA_BOOTSTRAP_SERVERS:localhost:9092}
    properties:
      security.protocol: ${KAFKA_SECURITY_PROTOCOL:PLAINTEXT}
      sasl.mechanism: ${KAFKA_SASL_MECHANISM:}
      sasl.login.callback.handler.class: ${KAFKA_SASL_LOGIN_CALLBACK_HANDLER:}
      sasl.oauthbearer.token.endpoint.url: ${KAFKA_OAUTH_TOKEN_ENDPOINT:}
      sasl.login.connect.timeout.ms: ${KAFKA_OAUTH_CONNECT_TIMEOUT:15000}
      sasl.jaas.config: org.apache.kafka.common.security.oauthbearer.OAuthBearerLoginModule required clientId="${KAFKA_OAUTH_CLIENT_ID:}" clientSecret="${KAFKA_OAUTH_CLIENT_SECRET:}" scope="${KAFKA_OAUTH_SCOPE:}";
    producer:
      key-serializer: org.apache.kafka.common.serialization.StringSerializer
      value-serializer: org.apache.kafka.common.serialization.StringSerializer
      acks: all
      retries: 3
      properties:
        linger.ms: ${KAFKA_PRODUCER_LINGER_MS:10}
        batch.size: ${KAFKA_PRODUCER_BATCH_SIZE:16384}
        compression.type: ${KAFKA_PRODUCER_COMPRESSION_TYPE:lz4}
        request.timeout.ms: ${KAFKA_PRODUCER_REQUEST_TIMEOUT_MS:20000}
        delivery.timeout.ms: ${KAFKA_PRODUCER_DELIVERY_TIMEOUT_MS:30000}
        max.block.ms: ${KAFKA_PRODUCER_MAX_BLOCK_MS:10000}
        enable.idempotence: true
    consumer:
      group-id: {{LibraryName}}.consumer
      auto-offset-reset: earliest
      enable-auto-commit: false
      key-deserializer: org.apache.kafka.common.serialization.StringDeserializer
      value-deserializer: org.apache.kafka.common.serialization.StringDeserializer

{{#unless IsFeatureLibrary}}
# Enable policy engine by default
gap:
  policy:
    enabled: true
    debug: false
  outbox:
    scheduler:
      enabled: ${GAP_OUTBOX_SCHEDULER_ENABLED:true}
      polling-interval-ms: ${GAP_OUTBOX_SCHEDULER_POLLING_INTERVAL_MS:1000}
      batch-size: ${GAP_OUTBOX_SCHEDULER_BATCH_SIZE:100}
      stale-threshold-minutes: ${GAP_OUTBOX_SCHEDULER_STALE_THRESHOLD_MINUTES:5}
      shedlock:
        lock-at-most-for: 5m
        lock-at-least-for: 1s
  events:
    topic-prefix: ${GAP_EVENTS_TOPIC_PREFIX:}
    topic-suffix: ${GAP_EVENTS_TOPIC_SUFFIX:}
    max-event-depth: ${GAP_EVENTS_MAX_DEPTH:20}
    retry:
      max-attempts: ${GAP_EVENTS_RETRY_MAX_ATTEMPTS:5}
      base-delay-ms: ${GAP_EVENTS_RETRY_BASE_DELAY_MS:1000}
      max-delay-ms: ${GAP_EVENTS_RETRY_MAX_DELAY_MS:60000}
  optimistic-locking:
    # Require version for update operations (If-Match header or version in body)
    # Set to false for admin tools or migration scripts
    require-version: ${GAP_OPTIMISTIC_LOCKING_REQUIRE_VERSION:false}
{{/unless}}
