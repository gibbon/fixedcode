                // Exclude OpenAPI generated code (compiled from build/generated/)
                exclude("**/api/controller/**")
                exclude("**/api/dto/**")
                exclude("**/SpringDocConfiguration*")
                exclude("**/ApiUtil*")
                
                // Exclude Spring configuration
                exclude("**/autoconfigure/**")
                exclude("**/config/**")

                // Exclude utility classes without business logic
                exclude("**/ValidationExceptionHandler*")
                exclude("**/DomainConfigImpl*")
                
                // Exclude DTOs and API models (generated)
                exclude("**/*Dto*")
                exclude("**/*Request*")
                exclude("**/*Response*")
                exclude("**/*Model*")
                
                // Exclude command data classes (simple value objects)
                exclude("**/commands/*Data.class")
                
                // Exclude test applications and main application class
                exclude("**/SkeletonTestApplication*")
                exclude("**/{{LibraryName}}Application*")
                exclude("**/{{LibraryName}}ApplicationKt*")
                exclude("**/*Application.class")
                exclude("**/*ApplicationKt.class")

                // Exclude Side Effect Outbox infrastructure (tested via SideEffectOutboxIntegrationTest)
                exclude("**/application/shared/SideEffect*")
                exclude("**/application/shared/SideEffect*\$*")
                exclude("**/domain/shared/SideEffect*")
                exclude("**/infrastructure/sideeffect/**")
                exclude("**/config/SideEffectProperties*")

                // Exclude Object Change Detection infrastructure
                exclude("**/shared/jsonfieldchange/**")

                // Exclude companion objects and loggers
                exclude("**/*\$Companion*.*")
                exclude("**/*\$\$serializer*.*")
                exclude("**/*\$logger*.*")
            }
        })
    )
}

