// Enhanced Jacoco coverage verification
tasks.jacocoTestCoverageVerification {
    val minimumThresholdValue = 0.10.toBigDecimal() // 10% threshold for domain/application code
    
    classDirectories.setFrom(
        files(classDirectories.files.map {
            fileTree(it).apply {
                // Exclude generated code from coverage
                exclude("**/generated/**")
                exclude("**/build/generated/**")
                exclude("**/buildconfig/**")
                exclude("**/BuildConfig*")
                
                // Exclude OpenAPI generated code (compiled from build/generated/)
                exclude("**/api/controller/**")
                exclude("**/api/dto/**")
                exclude("**/SpringDocConfiguration*")
                exclude("**/ApiUtil*")
                
                // Exclude API delegate implementations (thin wrappers around services)
                exclude("**/api/*ApiDelegateImpl*")
                
                // Exclude Spring configuration
                exclude("**/autoconfigure/**")
                exclude("**/config/**")

                // Exclude utility classes without business logic
                exclude("**/ValidationExceptionHandler*")
                exclude("**/DomainConfigImpl*")

                // Exclude interface default implementations (Kotlin generates these)
                exclude("**/*\$DefaultImpls*")
                
                // Exclude enums (simple data classes)
                exclude("**/enums/**")
                
                // Exclude shared domain utilities
                exclude("**/domain/shared/**")
                
                // Exclude repository interfaces (delegate to Spring Data, Impl classes are tested)
                exclude("**/infrastructure/repository/*Repository.class")
                
                // Exclude outbox event listener (tested via integration tests)
                exclude("**/OutboxEventListener*")
                
                // Exclude Side Effect Outbox infrastructure (scheduled jobs, tested via integration tests)
                // Exclude Side Effect Outbox infrastructure (tested via SideEffectOutboxIntegrationTest)
                exclude("**/application/shared/SideEffect*")
                exclude("**/domain/shared/SideEffect*")
                exclude("**/infrastructure/sideeffect/**")
                exclude("**/config/SideEffectProperties*")

                // Exclude Object Change Detection infrastructure
                exclude("**/shared/jsonfieldchange/**")
                
                // Exclude remote aggregate infrastructure (event handlers, repositories)
                exclude("**/events/handlers/**")
                exclude("**/infrastructure/remote/**")
                
                // Exclude FilterParser utility (tested via FilterParserTest)
                exclude("**/infrastructure/util/FilterParser*")
                
                // Exclude JoinConstraint data class (simple value object)
                exclude("**/infrastructure/util/JoinConstraint*")
                
                // Exclude domain validation services (tested via ValidationServiceTest)
                exclude("**/domain/**/Default*ValidationService*")

                // Exclude ParticipantAccessRepository (tested via integration tests, not unit tests)
                exclude("**/infrastructure/repository/ParticipantAccessRepository*")

                // Exclude QueryService interfaces and entity-level implementations (tested via integration tests)
                exclude("**/services/*QueryService.class")
                exclude("**/entities/**/services/Default*QueryService*")

                // Exclude DTOs and API models (generated)
                exclude("**/*Dto*")
                exclude("**/*Request*")
                exclude("**/*Response*")
                exclude("**/*Model*")
                
                // Exclude command data classes (simple value objects)
                exclude("**/commands/*Data.class")
                
                // Exclude minimal tier entity events (simple data classes for join tables)
                exclude("**/events/AssetParticipant*Event*")
                exclude("**/events/AssetParty*Event*")
                
                // Exclude application classes
                exclude("**/SkeletonTestApplication*")
                exclude("**/{{LibraryName}}Application*")
                exclude("**/{{LibraryName}}ApplicationKt*")
                exclude("**/*Application.class")
                exclude("**/*ApplicationKt.class")
                
                // Exclude Kotlin generated classes
                exclude("**/*\$Companion*.*")
                exclude("**/*\$\$serializer*.*")
                exclude("**/*\$logger*.*")
            }
        })
    )
    
    violationRules {
        rule {
            element = "CLASS"
            limit {
                counter = "LINE"
                minimum = minimumThresholdValue
            }
            limit {
                counter = "BRANCH"
                minimum = minimumThresholdValue
            }
            limit {
                counter = "METHOD"
                minimum = minimumThresholdValue
            }
            limit {
                counter = "CLASS"
                minimum = minimumThresholdValue
            }
            limit {
                counter = "COMPLEXITY"
                minimum = minimumThresholdValue
            }
        }
    }
}

