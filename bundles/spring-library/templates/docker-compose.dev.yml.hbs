{{#unless IsFeatureLibrary}}
services:
  # Library service for fast development with hot-reload
  {{LibraryName}}:
    build:
      context: ..
      dockerfile: build/{{LibraryName}}/Dockerfile.dev
    container_name: {{LibraryName}}
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - SPRING_DATASOURCE_URL=jdbc:postgresql://postgresql:5432/gap_db?currentSchema={{SchemaName}}
      - SPRING_DATASOURCE_READ_URL=jdbc:postgresql://postgresql:5434/gap_db?currentSchema={{SchemaName}}
      - SPRING_DATASOURCE_USERNAME=gap_user
      - SPRING_DATASOURCE_PASSWORD=gap_password
      - SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
      - ARTIFACTORY_USERNAME=${ARTIFACTORY_USERNAME}
      - ARTIFACTORY_TOKEN=${ARTIFACTORY_TOKEN}
      - ARTIFACTORY_URL=${ARTIFACTORY_URL}
      - JAVA_OPTS=-Xmx1g -Xms512m
      - GRADLE_OPTS=-Xmx1g -Dorg.gradle.daemon=false
    deploy:
      resources:
        limits:
          memory: 1.5G
        reservations:
          memory: 1.5G
    volumes:
      # Mount source code for live updates
      - ../build/{{LibraryName}}/src:/app/src:ro
      # Mount build output for Gradle continuous build
      - ../build/{{LibraryName}}/build:/app/build
      # Mount gradle cache to persist between restarts
      - gradle-cache-{{LibraryName}}:/root/.gradle
      # SSL certificates
      - ../remote-AUMELSBS-CA.pem:/etc/ssl/certs/ca-certificates.crt
    depends_on:
      postgresql:
        condition: service_healthy
      kafka:
        condition: service_healthy
    networks:
      - gap-network
    ports:
      - "{{ServerPort}}:8080"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

volumes:
  gradle-cache-{{LibraryName}}:

networks:
  gap-network:
    external: true
{{/unless}}
