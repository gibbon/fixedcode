{{#unless IsFeatureLibrary}}
#!/bin/bash
set -e

echo "Waiting for Debezium Connect to be ready..."
until curl -f http://localhost:8999/ > /dev/null 2>&1; do
  echo "Waiting for Debezium Connect..."
  sleep 5
done

echo "Debezium Connect is ready. Configuring outbox connector..."

# Create Debezium connector for outbox table
curl -X POST http://localhost:8999/connectors \
  -H "Content-Type: application/json" \
  -d '{
    "name": "{{LibraryName}}-outbox-connector",
    "config": {
      "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
      "tasks.max": "1",
      "database.hostname": "postgresql",
      "database.port": "5432",
      "database.user": "gap_user",
      "database.password": "gap_password",
      "database.dbname": "gap_db",
      "database.server.name": "{{LibraryName}}",
      "table.include.list": "{{BoundedContextLower}}.outbox",
      "slot.name": "debezium_{{BoundedContextLower}}",
      "publication.name": "dbz_{{BoundedContextLower}}_publication",
      "plugin.name": "pgoutput",
      "publication.autocreate.mode": "filtered",
      "topic.prefix": "{{LibraryName}}",
      "transforms": "outbox",
      "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
      "transforms.outbox.table.field.event.id": "event_id",
      "transforms.outbox.table.field.event.key": "aggregate_id",
      "transforms.outbox.table.field.event.type": "event_type",
      "transforms.outbox.table.field.event.payload": "payload",
      "transforms.outbox.table.field.event.timestamp": "created_at",
      "transforms.outbox.table.expand.json.payload": "true",
      "transforms.outbox.table.fields.additional.placement": "event_type:header:eventType,aggregate_id:envelope,aggregate_type:envelope,trace_id:envelope:traceId,causation_id:envelope:causationId",
      "transforms.outbox.route.by.field": "topic",
      "transforms.outbox.route.topic.replacement": "${routedByValue}",
      "tombstones.on.delete": "false",
      "skipped.operations": "d"
    }
  }'

echo ""
echo "Debezium connector configured successfully!"
echo "Events from outbox_event table will be published to Kafka topics based on event_type"
echo ""
echo "Kafka UI available at: http://localhost:9090"
echo "Debezium Connect API: http://localhost:8999"
{{/unless}}
