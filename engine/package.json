{
  "name": "fixedcode",
  "version": "0.2.0",
  "description": "Spec-driven, deterministic code generation engine. Same spec → same code, every time.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "fixedcode": "./bin/fixedcode.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "code-generation",
    "spec-driven",
    "deterministic",
    "yaml",
    "scaffolding",
    "ddd",
    "spring",
    "typescript",
    "ai",
    "llm"
  ],
  "author": "Tom D",
  "license": "Apache-2.0",
  "homepage": "https://github.com/gibbon/fixedcode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gibbon/fixedcode.git",
    "directory": "engine"
  },
  "bugs": {
    "url": "https://github.com/gibbon/fixedcode/issues"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "commander": "^13.0.0",
    "handlebars": "^4.7.0",
    "picomatch": "^4.0.4",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.3",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
